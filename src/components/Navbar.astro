---
import Icon from "./Icon.astro";

const services = [
  {
    name: "Soluciones de Software y SaaS",
    description: "Desarrollo de plataformas robustas y escalables listas para el mercado global.",
    href: "/servicios/software-saas",
    icon: "package"
  },
  {
    name: "Inteligencia Artificial",
    description: "Implementación de modelos LLM y agentes autónomos para optimizar tu operación.",
    href: "/servicios/inteligencia-artificial",
    icon: "cpu"
  },
  {
    name: "Desarrollo de Software",
    description: "Software a medida con arquitectura de vanguardia y foco en el rendimiento.",
    href: "/servicios/desarrollo-software",
    icon: "code"
  }
];

const products = [
  {
    name: "Thinka Agentes",
    description: "Tu equipo de agentes de IA 24/7 para atención y ventas.",
    href: "/productos/agentes",
    icon: "activity"
  },
  {
    name: "Thinka Dataguard",
    description: "Cumplimiento normativo y protección de datos Chile 2026.",
    href: "/productos/dataguard",
    icon: "shield"
  }
];
---

<header class="sticky top-0 z-50">
  <!-- Top Bar -->
  <div class="bg-gray-50 dark:bg-gray-950/50 border-b border-gray-100 dark:border-gray-800 hidden lg:block">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12 py-2 flex justify-between items-center text-xs font-medium text-gray-500 dark:text-gray-400">
      <div class="flex items-center space-x-6">
        <a href="mailto:hola@thinka.cl" class="flex items-center hover:text-purple-600 dark:hover:text-purple-400 transition-colors group">
          <div class="w-6 h-6 rounded-full bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center mr-2 group-hover:bg-purple-100 dark:group-hover:bg-purple-900/40 transition-colors">
            <Icon name="mail" size={12} class="text-purple-600 dark:text-purple-400" />
          </div>
          hola@thinka.cl
        </a>
        <div class="flex items-center">
          <div class="w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center mr-2">
            <Icon name="map-pin" size={12} />
          </div>
          Santiago, Chile
        </div>
      </div>
      <div class="flex items-center space-x-6">
        <a href="https://wa.me/56948894523" target="_blank" rel="noopener noreferrer" class="flex items-center text-green-600 dark:text-green-500 hover:text-green-700 dark:hover:text-green-400 transition-all font-bold group">
          <div class="w-6 h-6 rounded-full bg-green-50 dark:bg-green-900/20 flex items-center justify-center mr-2 group-hover:bg-green-100 dark:group-hover:bg-green-900/40 transition-colors">
            <Icon name="whatsapp" size={12} class="text-green-600 dark:text-green-500" />
          </div>
          WhatsApp: +56 9 4889 4523
        </a>
      </div>
    </div>
  </div>

  <!-- Main Navbar -->
  <nav class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-md border-b border-gray-100 dark:border-gray-800 shadow-sm">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
      <div class="flex justify-between items-center h-20 lg:h-24">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <a href="/" class="hover:scale-105 transition-transform duration-300">
            <img src="/assets/images/logo-thinka.png" alt="Thinka Logo" class="h-14 lg:h-18 w-auto dark:brightness-0 dark:invert" />
          </a>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center space-x-10">
          <!-- Dropdown Servicios -->
          <div class="relative group h-24 flex items-center">
            <button class="inline-flex items-center text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">
              Servicios
              <Icon name="arrow-right" size={14} class="ml-1 rotate-90 group-hover:rotate-[270deg] transition-transform duration-300" />
            </button>
            
            <!-- Mega Menu Dropdown -->
            <div class="absolute top-full left-1/2 -translate-x-1/2 w-[600px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out pt-2">
              <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-800 grid grid-cols-2 overflow-hidden">
                <div class="p-6 col-span-2 grid grid-cols-1 gap-4">
                  {services.map((service) => (
                    <a href={service.href} class="flex items-start p-4 rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-all duration-200 group/item">
                      <div class="flex-shrink-0 w-10 h-10 bg-purple-100 dark:bg-purple-900/40 rounded-lg flex items-center justify-center text-purple-600 dark:text-purple-400 group-hover/item:scale-110 transition-transform duration-300">
                        <Icon name={service.icon as any} size={20} />
                      </div>
                      <div class="ml-4">
                        <p class="text-sm font-bold text-gray-900 dark:text-white">{service.name}</p>
                        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{service.description}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Dropdown Productos -->
          <div class="relative group h-24 flex items-center">
            <button class="inline-flex items-center text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">
              Productos
              <Icon name="arrow-right" size={14} class="ml-1 rotate-90 group-hover:rotate-[270deg] transition-transform duration-300" />
            </button>
            
            <div class="absolute top-full left-1/2 -translate-x-1/2 w-[400px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out pt-2">
              <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-800 p-4 overflow-hidden">
                {products.map((product) => (
                  <a href={product.href} class="flex items-start p-4 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-all duration-200 group/item relative">
                    <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 dark:bg-indigo-900/40 rounded-lg flex items-center justify-center text-indigo-600 dark:text-indigo-400 group-hover/item:scale-110 transition-transform duration-300">
                      <Icon name={product.icon as any} size={20} />
                    </div>
                    <div class="ml-4">
                      <div class="flex items-center">
                        <p class="text-sm font-bold text-gray-900 dark:text-white">{product.name}</p>
                        {product.status && (
                          <span class="ml-2 px-1.5 py-0.5 text-[10px] font-bold bg-indigo-100 dark:bg-indigo-900 text-indigo-600 dark:text-indigo-400 rounded-md uppercase tracking-wider">
                            {product.status}
                          </span>
                        )}
                      </div>
                      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{product.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>

          <a href="/nosotros" class="text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">Nosotros</a>
          <a href="/contacto" class="text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">Contacto</a>
        </nav>

        <!-- Right Side Actions -->
        <div class="hidden lg:flex items-center space-x-6">
          <a href="/cotizar" class="inline-flex items-center justify-center px-8 py-3 text-sm font-bold text-white bg-gradient-to-r from-purple-600 to-indigo-600 rounded-full hover:shadow-xl hover:shadow-purple-500/40 hover:-translate-y-0.5 transition-all duration-300 active:scale-95 border border-purple-400/20">
            Cotizar Proyecto
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <div class="flex items-center lg:hidden">
          <button id="mobile-menu-btn" class="p-3 rounded-xl bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 shadow-sm border border-gray-100 dark:border-gray-700" aria-label="Abrir menú">
            <Icon name="menu" size={24} />
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile Menu Sidebar -->
<div id="mobile-menu-sidebar" class="fixed inset-0 z-[100] lg:hidden invisible opacity-0 transition-all duration-300">
  <div class="absolute inset-0 bg-gray-950/80 backdrop-blur-md" id="mobile-menu-overlay"></div>
  <div class="absolute right-0 top-0 bottom-0 w-full max-w-[300px] bg-white dark:bg-gray-900 shadow-2xl translate-x-full transition-transform duration-500 ease-in-out flex flex-col h-[100dvh]" id="mobile-menu-panel">
    <!-- Header del Sidebar -->
    <div class="p-6 flex justify-between items-center border-b border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 flex-shrink-0">
      <img src="/assets/images/logo-thinka.png" alt="Thinka Logo" class="h-10 w-auto dark:brightness-0 dark:invert" />
      <button id="close-mobile-menu" class="p-2 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-xl transition-colors border border-gray-100 dark:border-gray-800" aria-label="Cerrar menú">
        <Icon name="x" size={24} />
      </button>
    </div>
    
    <!-- Contenido Scrollable -->
    <div class="flex-1 overflow-y-auto p-6 space-y-10 custom-scrollbar">
      <!-- Sección Servicios -->
      <div>
        <p class="text-[11px] font-black text-purple-600 dark:text-purple-400 uppercase tracking-[0.2em] mb-6">Servicios</p>
        <div class="grid gap-3">
          {services.map(s => (
            <a href={s.href} class="flex items-center p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50 hover:bg-purple-50 dark:hover:bg-purple-900/20 text-gray-800 dark:text-gray-100 font-bold transition-all border border-transparent hover:border-purple-100 dark:hover:border-purple-800">
              <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-4">
                <Icon name={s.icon as any} size={18} />
              </div>
              <span class="text-sm">{s.name}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Sección Productos -->
      <div>
        <p class="text-[11px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-[0.2em] mb-6">Productos</p>
        <div class="grid gap-3">
          {products.map(p => (
            <a href={p.href} class="flex items-center p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 text-gray-800 dark:text-gray-100 font-bold transition-all border border-transparent hover:border-indigo-100 dark:hover:border-indigo-800">
              <div class="w-8 h-8 rounded-lg bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-4">
                <Icon name={p.icon as any} size={18} />
              </div>
              <span class="text-sm">{p.name}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Otros Enlaces -->
      <div class="space-y-2 pt-6 border-t border-gray-100 dark:border-gray-800">
        <a href="/nosotros" class="block p-4 rounded-2xl text-gray-800 dark:text-gray-100 font-bold hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">Nosotros</a>
        <a href="/contacto" class="block p-4 rounded-2xl text-gray-800 dark:text-gray-100 font-bold hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-all">Contacto</a>
      </div>

      <!-- Contacto Rápido Mobile -->
      <div class="pt-6 border-t border-gray-100 dark:border-gray-800 space-y-4">
        <p class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Contacto Directo</p>
        <a href="mailto:hola@thinka.cl" class="flex items-center p-4 rounded-2xl bg-purple-50/50 dark:bg-purple-900/10 text-purple-700 dark:text-purple-300 transition-all border border-purple-100/50 dark:border-purple-800/30">
          <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center mr-4">
            <Icon name="mail" size={18} />
          </div>
          <span class="text-sm font-bold">hola@thinka.cl</span>
        </a>
        <a href="https://wa.me/56948894523" target="_blank" rel="noopener noreferrer" class="flex items-center p-4 rounded-2xl bg-green-50/50 dark:bg-green-900/10 text-green-700 dark:text-green-400 transition-all border border-green-100/50 dark:border-green-800/30">
          <div class="w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/40 flex items-center justify-center mr-4">
            <Icon name="whatsapp" size={18} />
          </div>
          <span class="text-sm font-bold">WhatsApp: +56 9 4889 4523</span>
        </a>
      </div>
    </div>

    <!-- Footer del Sidebar -->
    <div class="p-6 border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 flex-shrink-0">
      <a href="/cotizar" class="flex items-center justify-center w-full py-5 rounded-2xl bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-black shadow-lg shadow-purple-500/20 hover:shadow-purple-500/30 transition-all active:scale-[0.98]">
        Cotizar Proyecto
      </a>
    </div>
  </div>
</div>

<script>
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const sidebar = document.getElementById('mobile-menu-sidebar');
  const panel = document.getElementById('mobile-menu-panel');
  const mobileLinks = sidebar?.querySelectorAll('a');

  function openMenu() {
    sidebar?.classList.remove('invisible', 'opacity-0');
    sidebar?.classList.add('visible', 'opacity-100');
    panel?.classList.remove('translate-x-full');
    panel?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sidebar?.classList.remove('visible', 'opacity-100');
    sidebar?.classList.add('invisible', 'opacity-0');
    panel?.classList.remove('translate-x-0');
    panel?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  // Cerrar menú al hacer clic en un enlace
  mobileLinks?.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e5e7eb;
    border-radius: 10px;
  }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #374151;
  }
</style>


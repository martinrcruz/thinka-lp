---
import Icon from "./Icon.astro";

const services = [
  {
    name: "Soluciones de Software y SaaS",
    description: "Desarrollo de plataformas robustas y escalables listas para el mercado global.",
    href: "/servicios/software-saas",
    icon: "package"
  },
  {
    name: "Inteligencia Artificial",
    description: "Implementación de modelos LLM y agentes autónomos para optimizar tu operación.",
    href: "/servicios/inteligencia-artificial",
    icon: "cpu"
  },
  {
    name: "Desarrollo de Software",
    description: "Software a medida con arquitectura de vanguardia y foco en el rendimiento.",
    href: "/servicios/desarrollo-software",
    icon: "code"
  }
];

const products = [
  {
    name: "Thinka Asistente",
    description: "Tu agente de IA 24/7 para atención al cliente y ventas automatizadas.",
    href: "/productos/asistente",
    icon: "activity"
  },
  {
    name: "Thinka CRM",
    description: "Gestión inteligente de relaciones con clientes potenciada por IA.",
    href: "/productos/crm",
    icon: "shield",
    status: "Próximamente"
  }
];
---

<header class="bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-100 dark:border-gray-800 sticky top-0 z-50">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
    <div class="flex justify-between items-center h-24">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="hover:scale-105 transition-transform duration-300">
          <img src="/assets/images/logo-thinka.png" alt="Thinka Logo" class="h-20 w-auto dark:brightness-0 dark:invert" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-10">
        <!-- Dropdown Servicios -->
        <div class="relative group h-24 flex items-center">
          <button class="inline-flex items-center text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">
            Servicios
            <Icon name="arrow-right" size={14} class="ml-1 rotate-90 group-hover:rotate-[270deg] transition-transform duration-300" />
          </button>
          
          <!-- Mega Menu Dropdown -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 w-[600px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out pt-2">
            <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-800 overflow-hidden grid grid-cols-2">
              <div class="p-6 col-span-2 grid grid-cols-1 gap-4">
                {services.map((service) => (
                  <a href={service.href} class="flex items-start p-4 rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-all duration-200 group/item">
                    <div class="flex-shrink-0 w-10 h-10 bg-purple-100 dark:bg-purple-900/40 rounded-lg flex items-center justify-center text-purple-600 dark:text-purple-400 group-hover/item:scale-110 transition-transform duration-300">
                      <Icon name={service.icon as any} size={20} />
                    </div>
                    <div class="ml-4">
                      <p class="text-sm font-bold text-gray-900 dark:text-white">{service.name}</p>
                      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{service.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Dropdown Productos -->
        <div class="relative group h-24 flex items-center">
          <button class="inline-flex items-center text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">
            Productos
            <Icon name="arrow-right" size={14} class="ml-1 rotate-90 group-hover:rotate-[270deg] transition-transform duration-300" />
          </button>
          
          <div class="absolute top-full left-1/2 -translate-x-1/2 w-[400px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out pt-2">
            <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-800 p-4">
              {products.map((product) => (
                <a href={product.href} class="flex items-start p-4 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-all duration-200 group/item relative">
                  <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 dark:bg-indigo-900/40 rounded-lg flex items-center justify-center text-indigo-600 dark:text-indigo-400 group-hover/item:scale-110 transition-transform duration-300">
                    <Icon name={product.icon as any} size={20} />
                  </div>
                  <div class="ml-4">
                    <div class="flex items-center">
                      <p class="text-sm font-bold text-gray-900 dark:text-white">{product.name}</p>
                      {product.status && (
                        <span class="ml-2 px-1.5 py-0.5 text-[10px] font-bold bg-indigo-100 dark:bg-indigo-900 text-indigo-600 dark:text-indigo-400 rounded-md uppercase tracking-wider">
                          {product.status}
                        </span>
                      )}
                    </div>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{product.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/nosotros" class="text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">Nosotros</a>
        <a href="/contacto" class="text-sm font-semibold text-gray-600 dark:text-gray-300 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-200">Contacto</a>
      </nav>

      <!-- Right Side Actions -->
      <div class="hidden lg:flex items-center space-x-6">
        <a href="/cotizar" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white bg-gradient-to-r from-purple-600 to-indigo-600 rounded-full hover:shadow-lg hover:shadow-purple-500/30 hover:-translate-y-0.5 transition-all duration-300 active:scale-95">
          Cotizar Proyecto
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="flex items-center lg:hidden">
        <button id="mobile-menu-btn" class="p-2 rounded-xl bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200">
          <Icon name="menu" size={24} />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Sidebar -->
  <div id="mobile-menu-sidebar" class="fixed inset-0 z-[60] lg:hidden invisible opacity-0 transition-all duration-300">
    <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm" id="mobile-menu-overlay"></div>
    <div class="absolute right-0 top-0 bottom-0 w-[300px] bg-white dark:bg-gray-900 shadow-2xl translate-x-full transition-transform duration-300 p-6 flex flex-col" id="mobile-menu-panel">
      <div class="flex justify-between items-center mb-10">
        <img src="/assets/images/logo-thinka.png" alt="Thinka Logo" class="h-16 w-auto dark:brightness-0 dark:invert" />
        <button id="close-mobile-menu" class="p-2 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg">
          <Icon name="x" size={24} />
        </button>
      </div>
      
      <div class="flex-grow overflow-y-auto space-y-6">
        <div>
          <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4">Servicios</p>
          <div class="space-y-2">
            {services.map(s => (
              <a href={s.href} class="block p-3 rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 text-gray-700 dark:text-gray-200 font-medium">{s.name}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4">Productos</p>
          <div class="space-y-2">
            {products.map(p => (
              <a href={p.href} class="block p-3 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/20 text-gray-700 dark:text-gray-200 font-medium">{p.name}</a>
            ))}
          </div>
        </div>

        <div class="space-y-2 pt-4 border-t border-gray-100 dark:border-gray-800">
          <a href="/nosotros" class="block p-3 text-gray-700 dark:text-gray-200 font-medium">Nosotros</a>
          <a href="/contacto" class="block p-3 text-gray-700 dark:text-gray-200 font-medium">Contacto</a>
        </div>
      </div>

      <div class="pt-6 mt-auto">
        <a href="/cotizar" class="flex items-center justify-center w-full py-4 rounded-xl bg-purple-600 text-white font-bold hover:bg-purple-700 transition-all duration-300">
          Cotizar Proyecto
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const sidebar = document.getElementById('mobile-menu-sidebar');
  const panel = document.getElementById('mobile-menu-panel');

  function openMenu() {
    sidebar?.classList.remove('invisible', 'opacity-0');
    sidebar?.classList.add('visible', 'opacity-100');
    panel?.classList.remove('translate-x-full');
    panel?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sidebar?.classList.remove('visible', 'opacity-100');
    sidebar?.classList.add('invisible', 'opacity-0');
    panel?.classList.remove('translate-x-0');
    panel?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>


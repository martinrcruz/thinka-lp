---
import Icon from "./Icon.astro";

const products = [
  {
    id: "agentes",
    name: "Thinka Agentes",
    tagline: "IA Conversacional & RAG",
    description: "Agentes inteligentes que entienden tu negocio, consultan tus bases de datos y atienden clientes 24/7 en WhatsApp, Instagram y Web.",
    features: ["Integración Omnicanal", "RAG (Conocimiento Interno)", "Agendamiento Automático"],
    href: "/productos/agentes",
    icon: "activity",
    color: "blue"
  },
  {
    id: "dataguard",
    name: "Thinka Dataguard",
    tagline: "Cumplimiento de Datos",
    description: "Software especializado en el cumplimiento de la nueva normativa de protección de datos en Chile (Diciembre 2026). Backend robusto en Rust.",
    features: ["Ley de Datos Chile 2026", "Backend en Rust Seguro", "Auditoría Automatizada"],
    href: "/productos/dataguard",
    icon: "shield",
    color: "indigo"
  },
  {
    id: "analitica",
    name: "Thinka Analítica",
    tagline: "Business Intelligence con IA",
    description: "Plataforma de BI avanzada con IA, RAG y soporte para protocolos MCP. Conecta todas tus fuentes de datos en un solo lugar.",
    features: ["IA & RAG Integration", "Protocolo MCP", "Detección de Anomalías"],
    href: "#",
    icon: "chart",
    color: "purple",
    status: "Próximamente"
  }
];

const colorClasses = {
  blue: "from-blue-500/20 to-cyan-500/20 text-blue-600 dark:text-blue-400 border-blue-100 dark:border-blue-900/40",
  indigo: "from-indigo-500/20 to-purple-500/20 text-indigo-600 dark:text-indigo-400 border-indigo-100 dark:border-indigo-900/40",
  purple: "from-purple-500/20 to-pink-500/20 text-purple-600 dark:text-purple-400 border-purple-100 dark:border-purple-900/40"
};
---

<section id="products" class="py-24 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none overflow-hidden">
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-purple-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-indigo-500/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-20">
      <h2 class="text-base text-purple-600 font-bold tracking-widest uppercase mb-4">Ecosistema Thinka</h2>
      <p class="text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-[1.2]">
        Productos que <span class="bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent">redefinen</span> industrias
      </p>
      <p class="mt-6 text-xl text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
        Nuestras soluciones propietarias combinan años de experiencia en software con la potencia de la Inteligencia Artificial moderna.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      {products.map((product) => (
        <div class="group relative bg-white dark:bg-gray-900 rounded-[2.5rem] p-1 border border-gray-100 dark:border-gray-800 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 overflow-hidden">
          {/* Status Badge */}
          {product.status && (
            <div class="absolute top-6 right-6 z-10">
              <span class="px-3 py-1 text-[10px] font-bold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full uppercase tracking-widest border border-gray-200 dark:border-gray-700">
                {product.status}
              </span>
            </div>
          )}

          <div class="p-8 h-full flex flex-col">
            <!-- Icon & Header -->
            <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${colorClasses[product.color as keyof typeof colorClasses]} flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500`}>
              <Icon name={product.icon as any} size={32} />
            </div>

            <div>
              <p class="text-xs font-bold text-purple-600 uppercase tracking-widest mb-2">{product.tagline}</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{product.name}</h3>
              <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-8 text-sm">
                {product.description}
              </p>
            </div>

            <!-- Features List -->
            <ul class="space-y-3 mb-10 mt-auto">
              {product.features.map(f => (
                <li class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                  <div class="mr-3 w-5 h-5 bg-purple-100 dark:bg-purple-900/40 rounded-full flex items-center justify-center flex-shrink-0">
                    <Icon name="check" size={10} class="text-purple-600 dark:text-purple-400" />
                  </div>
                  {f}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a 
              href={product.href} 
              class={`w-full py-4 px-6 rounded-2xl text-center font-bold text-sm transition-all duration-300 ${
                product.status 
                ? 'bg-gray-50 dark:bg-gray-800 text-gray-400 cursor-not-allowed border border-gray-100 dark:border-gray-700' 
                : 'bg-gray-900 dark:bg-white text-white dark:text-gray-900 hover:shadow-lg hover:shadow-purple-500/20'
              }`}
            >
              {product.status ? 'Notificar disponibilidad' : 'Ver Detalles del Producto'}
            </a>
          </div>

          {/* Decorative background pulse */}
          <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-purple-500/5 rounded-full blur-3xl group-hover:bg-purple-500/10 transition-colors duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import Icon from "./Icon.astro";

const products = [
  {
    id: "asistente-interno",
    name: "Asistente Interno de Conocimiento",
    tagline: "Búsqueda Documental",
    description: "Un asistente que responde preguntas sobre políticas, procedimientos, contratos y manuales usando los documentos de tu empresa.",
    features: ["Menos interrupciones", "Respuestas consistentes", "Menor dependencia"],
    href: "#",
    icon: "activity",
    color: "purple"
  },
  {
    id: "soporte-cliente",
    name: "Asistente de Soporte",
    tagline: "Atención 24/7",
    description: "Responde consultas frecuentes, clasifica casos y deriva los más complejos. Reduce carga operativa del equipo humano.",
    features: ["Reducción de carga", "Atención fuera de horario", "Mejor primera respuesta"],
    href: "#",
    icon: "cpu",
    color: "indigo"
  },
  {
    id: "automatizacion-correos",
    name: "Automatización de Correos",
    tagline: "Clasificación Inteligente",
    description: "La IA clasifica solicitudes, resume contenido, detecta urgencia, sugiere respuesta y deriva al área correcta.",
    features: ["Menos tiempo administrativo", "Mejor priorización", "Trazabilidad del flujo"],
    href: "#",
    icon: "package",
    color: "blue"
  },
  {
    id: "asistente-comercial",
    name: "Asistente Comercial",
    tagline: "Velocidad de Respuesta",
    description: "Ayuda a responder preguntas, clasificar leads, preparar borradores de propuesta y hacer seguimiento comercial.",
    features: ["Más velocidad comercial", "Mejor calificación", "Menos tareas repetitivas"],
    href: "#",
    icon: "shield",
    color: "purple"
  },
  {
    id: "busqueda-documentos",
    name: "Búsqueda Inteligente",
    tagline: "Consultas en Lenguaje Natural",
    description: "Consulta PDF, contratos, manuales e informes usando lenguaje natural. Encuentra respuestas sin revisar documento por documento.",
    features: ["Menos tiempo de búsqueda", "Mejor acceso al conocimiento", "Menos errores"],
    href: "#",
    icon: "chart",
    color: "indigo"
  },
  {
    id: "reportes-automatizados",
    name: "Reportes Automatizados",
    tagline: "Ahorro de Horas",
    description: "Automatizamos la preparación de reportes recurrentes con datos, resúmenes y observaciones listas para revisar.",
    features: ["Ahorro de horas semanales", "Reportes consistentes", "Mejor visibilidad"],
    href: "#",
    icon: "code",
    color: "blue"
  }
];

const colorClasses = {
  blue: "from-blue-500/20 to-cyan-500/20 text-blue-600 dark:text-blue-400 border-blue-100 dark:border-blue-900/40",
  indigo: "from-indigo-500/20 to-purple-500/20 text-indigo-600 dark:text-indigo-400 border-indigo-100 dark:border-indigo-900/40",
  purple: "from-purple-500/20 to-pink-500/20 text-purple-600 dark:text-purple-400 border-purple-100 dark:border-purple-900/40"
};
---

<section id="products" class="py-24 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none overflow-hidden">
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-purple-500/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-indigo-500/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-20">
      <h2 class="text-base text-purple-600 font-bold tracking-widest uppercase mb-4">Casos de Uso</h2>
      <p class="text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-[1.2]">
        Procesos que <span class="bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent">transformamos</span>
      </p>
      <p class="mt-6 text-xl text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
        Cada asistente y automatización se diseña para resolver procesos concretos de tu empresa, no pruebas aisladas o pilotos que nunca llegan a producción.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product) => (
        <div class="group relative bg-white dark:bg-gray-900 rounded-[2.5rem] p-1 border border-gray-100 dark:border-gray-800 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 overflow-hidden">
          <div class="p-8 h-full flex flex-col">
            <!-- Icon & Header -->
            <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${colorClasses[product.color as keyof typeof colorClasses]} flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500`}>
              <Icon name={product.icon as any} size={32} />
            </div>

            <div>
              <p class="text-xs font-bold text-purple-600 uppercase tracking-widest mb-2">{product.tagline}</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{product.name}</h3>
              <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-8 text-sm">
                {product.description}
              </p>
            </div>

            <!-- Features List -->
            <ul class="space-y-3 mb-10 mt-auto">
              {product.features.map(f => (
                <li class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                  <div class="mr-3 w-5 h-5 bg-purple-100 dark:bg-purple-900/40 rounded-full flex items-center justify-center flex-shrink-0">
                    <Icon name="check" size={10} class="text-purple-600 dark:text-purple-400" />
                  </div>
                  {f}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a 
              href="#contact" 
              class="w-full py-4 px-6 rounded-2xl text-center font-bold text-sm transition-all duration-300 bg-gray-900 dark:bg-white text-white dark:text-gray-900 hover:shadow-lg hover:shadow-purple-500/20"
            >
              Solicitar información
            </a>
          </div>

          {/* Decorative background pulse */}
          <div class="absolute -bottom-20 -right-20 w-40 h-40 bg-purple-500/5 rounded-full blur-3xl group-hover:bg-purple-500/10 transition-colors duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import Icon from "./Icon.astro";
---

<section class="relative bg-white dark:bg-gray-900 overflow-hidden">
  <!-- Dynamic Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"%239C92AC\" fill-opacity=\"0.05\" fill-rule=\"evenodd\"%3E%3Ccircle cx=\"3\" cy=\"3\" r=\"3\"/%3E%3C/g%3E%3C/svg%3E')] bg-repeat opacity-30"></div>
  </div>

  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12 pt-4 pb-20 relative z-10">
    <div class="lg:grid lg:grid-cols-[1.1fr_0.9fr] lg:gap-16 items-center mb-16">
      <div class="sm:text-center lg:text-left">
        <div class="inline-flex items-center px-4 py-2 rounded-full border border-purple-100 bg-purple-50/50 dark:bg-purple-900/20 dark:border-purple-800/50 text-purple-700 dark:text-purple-300 text-sm font-bold mb-8 animate-fade-in">
          <span class="flex h-2 w-2 rounded-full bg-purple-600 mr-3 animate-ping"></span>
          SaaS, Software e Inteligencia Artificial
        </div>
        
        <h1 class="text-5xl sm:text-6xl lg:text-[3.2rem] xl:text-[4.5rem] font-black text-gray-900 dark:text-white leading-[1.1] tracking-tight mb-8">
          <span class="block">Ingeniería de Software</span>
          <span class="block bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent italic pb-4 -mb-4 pr-4 xl:whitespace-nowrap">potenciada por IA</span>
        </h1>
        
        <p class="mt-8 text-xl text-gray-600 dark:text-gray-300 max-w-2xl sm:mx-auto lg:mx-0 leading-relaxed font-medium">
          Desarrollamos plataformas SaaS escalables y soluciones de Inteligencia Artificial que optimizan tus operaciones y potencian tu ROI. De la idea al código en tiempo récord.
        </p>
        
        <div class="mt-12 flex flex-col sm:flex-row gap-5 sm:justify-center lg:justify-start">
          <a href="/cotizar" id="hero-primary-cta" class="group inline-flex justify-center items-center px-10 py-5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-lg font-bold rounded-2xl hover:shadow-2xl hover:shadow-purple-500/20 transition-all duration-300 hover:-translate-y-1 active:scale-95">
            Iniciar Consultoría Estratégica
            <Icon name="arrow-right" size={20} class="ml-3 group-hover:translate-x-1 transition-transform" />
          </a>
          <a href="#services" id="hero-secondary-cta" class="inline-flex justify-center items-center px-10 py-5 border-2 border-gray-100 dark:border-gray-800 text-lg font-bold rounded-2xl text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all duration-300 hover:shadow-xl active:scale-95">
            Ver Nuestros Productos
          </a>
        </div>
      </div>

      <div class="mt-20 lg:mt-0 relative">
        <div class="relative z-10 animate-float">
          <div class="relative bg-gradient-to-br from-white to-gray-50 dark:from-gray-800 dark:to-gray-900 p-2 rounded-[3rem] shadow-2xl border border-gray-100 dark:border-gray-700">
            <img
              src="/assets/images/main-hero-image.png"
              width="800"
              height="800"
              alt="Soluciones de Software y IA Thinka"
              class="rounded-[2.5rem] w-full h-auto object-cover shadow-inner"
              loading="eager"
            />
            <!-- Overlay element -->
            <div class="absolute -bottom-10 -left-10 bg-white dark:bg-gray-800 p-6 rounded-3xl shadow-2xl border border-gray-100 dark:border-gray-700 hidden sm:block">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-green-500 rounded-2xl flex items-center justify-center text-white">
                  <Icon name="activity" size={24} />
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Sistemas Activos</p>
                  <p class="text-xl font-black text-gray-900 dark:text-white">99.9% Uptime</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Decorative shapes -->
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-purple-600/10 rounded-full blur-3xl -z-10"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-indigo-600/10 rounded-full blur-3xl -z-10"></div>
      </div>
    </div>

    <!-- Full width horizontal items -->
    <div class="pt-12 border-t border-gray-100 dark:border-gray-800 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-purple-600 group-hover:scale-110 transition-transform">
          <Icon name="check" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">Arquitectura Escalable</span>
      </div>
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center text-indigo-600 group-hover:scale-110 transition-transform">
          <Icon name="cpu" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">IA de Vanguardia</span>
      </div>
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
          <Icon name="package" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">Infraestructura Cloud</span>
      </div>
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/40 flex items-center justify-center text-green-600 group-hover:scale-110 transition-transform">
          <Icon name="shield" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">Seguridad Avanzada</span>
      </div>
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-orange-100 dark:bg-orange-900/40 flex items-center justify-center text-orange-600 group-hover:scale-110 transition-transform">
          <Icon name="activity" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">Cumplimiento Legal</span>
      </div>
      <div class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-red-100 dark:bg-red-900/40 flex items-center justify-center text-red-600 group-hover:scale-110 transition-transform">
          <Icon name="eye" size={20} />
        </div>
        <span class="text-sm font-bold text-gray-500 dark:text-gray-400">Soporte 24/7</span>
      </div>
    </div>
  </div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }
    .animate-float {
      animation: float 6s ease-in-out infinite;
    }
    .animate-fade-in {
      animation: fadeIn 1s ease-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</section>


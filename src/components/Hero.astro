---
// Placeholder for hero image - you should add a real image to src/assets/images
// import heroImage from '../assets/images/hero-ai.png'; 
---

<section class="relative bg-white dark:bg-gray-900 overflow-hidden noise-texture">
  <!-- Sutil gradiente de fondo -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-indigo-50/30 dark:from-purple-950/10 dark:to-indigo-950/5 pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12 py-24 lg:py-32 relative z-10 parallax-content">
    <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
      <div class="sm:text-center md:max-w-3xl md:mx-auto lg:col-span-7 lg:text-left">
        <div class="inline-flex items-center px-3 py-1 rounded-full border border-purple-200 bg-purple-50 text-purple-800 text-sm font-medium mb-6 transition-all duration-300 hover:scale-105">
          <span class="flex h-2 w-2 rounded-full bg-purple-600 mr-2 animate-pulse"></span>
          Agencia de IA Global
        </div>
        <h1 class="text-5xl tracking-tight font-extrabold text-gray-900 dark:text-white sm:text-6xl md:text-7xl lg:text-6xl xl:text-7xl leading-tight">
          <span class="block xl:inline">Automatización de</span>
          <span class="block text-purple-600 xl:inline">procesos con IA</span>
        </h1>
        <p class="mt-6 text-lg text-gray-500 dark:text-gray-300 sm:text-xl sm:max-w-2xl sm:mx-auto md:text-2xl lg:mx-0 leading-relaxed">
          Transformamos empresas en todo el mundo con soluciones de Inteligencia Artificial que optimizan costos y maximizan la eficiencia operativa. Consultoría tecnológica de vanguardia.
        </p>
        <div class="mt-10 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0">
          <div class="flex flex-col sm:flex-row gap-5">
            <a href="#contact" class="inline-flex justify-center items-center px-10 py-4 border border-transparent text-lg font-bold rounded-xl text-white bg-purple-600 hover:bg-purple-700 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 active:scale-95">
              Agenda una Consultoría
            </a>
            <a href="#services" class="inline-flex justify-center items-center px-10 py-4 border-2 border-gray-200 dark:border-gray-700 text-lg font-bold rounded-xl text-gray-700 dark:text-gray-200 bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 active:scale-95">
              Ver Servicios
            </a>
          </div>
          <p class="mt-5 text-sm text-gray-500 dark:text-gray-400 font-medium italic">
            Expertos en arquitecturas token-efficient y optimización de costos.
          </p>
        </div>
      </div>
      <div class="mt-16 lg:mt-0 lg:col-span-5">
        <div class="relative mx-auto w-full lg:max-w-xl group">
            <!-- Brillo decorativo detrás de la imagen -->
            <div class="absolute -inset-4 bg-gradient-to-tr from-purple-500/20 to-indigo-500/20 blur-3xl opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative block w-full rounded-2xl overflow-hidden bg-white/80 dark:bg-gray-800/80 shadow-2xl hero-image-container backdrop-blur-sm border border-white/20 dark:border-gray-700/30">
              <img
                src="/assets/images/hero-image-1-main.png"
                width="1024"
                height="1024"
                alt="Inteligencia Artificial Avanzada por Thinka"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                class="w-full h-full object-contain p-4 sm:p-6 hero-blur-effect transition-transform duration-1000 group-hover:scale-110"
              />
              <!-- Overlay para suavizar bordes con blur -->
              <div class="absolute inset-0 pointer-events-none hero-edge-blur"></div>
            </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Ruido CSS al 5% de opacidad */
    .noise-texture::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      opacity: 0.05;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    /* Efecto de difuminación en los bordes */
    .hero-edge-blur {
      box-shadow: inset 0 0 20px 10px rgba(255, 255, 255, 1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      mask-image: radial-gradient(circle, transparent 60%, black 100%);
      -webkit-mask-image: radial-gradient(circle, transparent 60%, black 100%);
    }

    :global([data-theme="dark"]) .hero-edge-blur {
      box-shadow: inset 0 0 20px 10px rgba(17, 24, 39, 1);
    }

    .hero-blur-effect {
      filter: blur(0px);
      transition: filter 0.3s ease;
    }

    /* Parallax suave */
    @media (min-width: 1024px) {
      .parallax-content {
        animation: float 6s ease-in-out infinite;
      }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    /* Breakpoints personalizados */
    @media (min-width: 320px) { /* Mobile small */ }
    @media (min-width: 768px) { /* Tablet */ }
    @media (min-width: 1024px) { /* Desktop */ }
    @media (min-width: 1440px) { /* Ultra-wide */ }
  </style>

  
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 opacity-20">
    <svg width="404" height="404" fill="none" viewBox="0 0 404 404" aria-hidden="true" class="text-purple-200 dark:text-purple-900">
      <defs>
        <pattern id="de316486-4a29-4312-bdfc-fbce2132a2c1" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <rect x="0" y="0" width="4" height="4" fill="currentColor" />
        </pattern>
      </defs>
      <rect width="404" height="404" fill="url(#de316486-4a29-4312-bdfc-fbce2132a2c1)" />
    </svg>
  </div>
</section>

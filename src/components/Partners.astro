---
const partners = [
  { name: "OpenAI", logo: "/assets/images/partners/openai-logo.png" },
  { name: "Claude", logo: "/assets/images/partners/claude-logo.png" },
  { name: "DeepSeek", logo: "/assets/images/partners/deepseek-logo.png" },
  { name: "Ollama", logo: "/assets/images/partners/ollama-logo.webp" },
  { name: "DigitalOcean", logo: "/assets/images/partners/DigitalOcean-logo.png" },
];
---

<section class="py-16 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12">
      <h3 class="text-[10px] font-bold text-brand-slate uppercase tracking-[0.3em]">
        Intelligence Stack & Trusted Partners
      </h3>
    </div>
    <div class="flex flex-wrap justify-center items-center gap-12 md:gap-20">
      {partners.map((partner) => (
        <div class="group relative flex justify-center items-center h-12 w-32 md:w-40 transition-all duration-700">
          <img 
            src={partner.logo} 
            alt={`Logo de ${partner.name}`} 
            class="max-w-full max-h-full object-contain filter grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-110"
            loading="lazy"
          />
          <!-- Glow effect on hover -->
          <div class="absolute inset-0 bg-brand-primary/5 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-full"></div>
        </div>
      ))}
    </div>
  </div>
</section>

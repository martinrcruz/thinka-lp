---
import Icon from "./Icon.astro";
const clients = [
  { name: "Alabarteam", logo: "/assets/images/clients/alabarteam-logo.jpg" },
  { name: "Extinguidor", logo: "/assets/images/clients/extinguidor-logo.png" },
  { name: "Fenorte", logo: "/assets/images/clients/fenorte-logo.png" },
  { name: "Lubeal", logo: "/assets/images/clients/lubeal-logo.png", invert: true },
];

const reasons = [
  {
    title: "Excelencia Técnica",
    description: "Expertos en desarrollo de Software, SaaS y Machine Learning con historial de éxito comprobado.",
    icon: "code",
    color: "purple"
  },
  {
    title: "Foco en Resultados",
    description: "No solo implementamos tecnología; garantizamos un ROI medible y optimización de procesos operativos.",
    icon: "chart",
    color: "indigo"
  },
  {
    title: "Socio Estratégico",
    description: "Atención directa y comprensión profunda de los objetivos de tu negocio para soluciones a medida.",
    icon: "briefcase",
    color: "blue"
  }
];

const colorClasses = {
  purple: "bg-purple-100 text-purple-600 dark:bg-purple-900/40 dark:text-purple-400",
  indigo: "bg-indigo-100 text-indigo-600 dark:bg-indigo-900/40 dark:text-indigo-400",
  blue: "bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400"
};
---

<section class="py-24 bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16">
      <h2 class="text-sm font-bold text-purple-600 uppercase tracking-[0.2em] mb-4">Confianza Corporativa</h2>
      <p class="text-3xl lg:text-4xl font-extrabold text-gray-900 dark:text-white">
        Empresas que ya están <span class="text-purple-600 italic">transformando</span> su futuro con Thinka
      </p>
    </div>
    
    <!-- Client Logos Grid -->
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 lg:grid-cols-4 items-center justify-items-center mb-24 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-700">
      {clients.map((client) => (
        <div class="group flex justify-center items-center p-8 bg-gray-50 dark:bg-gray-800/50 rounded-[2rem] border border-transparent hover:border-purple-100 dark:hover:border-purple-900/30 hover:bg-white dark:hover:bg-gray-800 transition-all duration-300 w-full h-32 relative overflow-hidden">
          <img 
            src={client.logo} 
            alt={`Logo de ${client.name}`} 
            class={`max-w-[120px] max-h-full object-contain filter drop-shadow-sm transition-transform duration-500 group-hover:scale-110 ${(client as any).invert ? 'brightness-0 contrast-200 opacity-100' : ''}`}
          />
        </div>
      ))}
    </div>

    <!-- Value Props -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {reasons.map((reason) => (
        <div class="relative group">
          <div class={`flex items-center justify-center h-16 w-16 rounded-2xl ${colorClasses[reason.color as keyof typeof colorClasses]} mb-8 group-hover:scale-110 transition-transform duration-500 shadow-sm`}>
            <Icon name={reason.icon as any} size={28} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4 group-hover:text-purple-600 transition-colors">{reason.title}</h3>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
            {reason.description}
          </p>
          {/* Subtle line decoration */}
          <div class="absolute -bottom-4 left-0 w-12 h-1 bg-gradient-to-r from-purple-600 to-transparent rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      ))}
    </div>
  </div>
</section>


---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-800 text-white">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-1">
        <img src="/assets/images/logo-thinka.png" alt="Thinka Logo" class="h-12 w-auto mb-4 brightness-0 invert" />
        <p class="mt-2 text-sm text-gray-400">
          Expertos en Software, SaaS e Inteligencia Artificial.
        </p>
      </div>
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">Servicios</h3>
        <ul class="mt-4 space-y-4">
          <li><a href="#services" class="text-base text-gray-300 hover:text-white">Software a Medida</a></li>
          <li><a href="#services" class="text-base text-gray-300 hover:text-white">Plataformas SaaS</a></li>
          <li><a href="#services" class="text-base text-gray-300 hover:text-white">Inteligencia Artificial</a></li>
        </ul>
      </div>
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">Empresa</h3>
        <ul class="mt-4 space-y-4">
          <li><a href="#about" class="text-base text-gray-300 hover:text-white">Nosotros</a></li>
          <li><a href="#contact" class="text-base text-gray-300 hover:text-white">Contacto</a></li>
          <li><a href="/privacidad" class="text-base text-gray-300 hover:text-white">Privacidad</a></li>
        </ul>
      </div>
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">Contacto</h3>
        <ul class="mt-4 space-y-4">
          <li class="flex items-center text-gray-300">
            <Icon name="mail" size={20} class="h-5 w-5 mr-2" />
            contacto@thinka.cl
          </li>
          <li class="flex items-center text-gray-300">
            <Icon name="map-pin" size={20} class="mr-2" />
            Remoto / Global
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-gray-700 pt-8 md:flex md:items-center md:justify-between">
      <div class="flex space-x-6 md:order-2">
        <a href="https://www.linkedin.com/company/thinka-cl/" class="text-gray-400 hover:text-gray-300" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">LinkedIn</span>
          <Icon name="linkedin" size={24} class="h-6 w-6" />
        </a>
      </div>
      <p class="mt-8 text-base text-gray-400 md:mt-0 md:order-1">
        &copy; {currentYear} Thinka. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

---
import Icon from "./Icon.astro";
---

<section id="contact" class="py-24 bg-white dark:bg-gray-900 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative bg-gray-900 rounded-[3rem] shadow-2xl overflow-hidden border border-gray-800 lg:grid lg:grid-cols-2 lg:gap-4">
      <div class="pt-16 pb-12 px-8 sm:pt-20 sm:px-16 lg:py-24 lg:pr-0 xl:py-32 xl:px-24">
        <div class="lg:self-center">
          <h2 class="text-4xl font-black text-white sm:text-5xl leading-[1.2]">
            <span class="block">¿Listo para escalar</span>
            <span class="block text-purple-500 italic text-5xl sm:text-6xl">con IA?</span>
          </h2>
          <p class="mt-8 text-xl leading-relaxed text-gray-400">
            Agenda una consultoría técnica de 15 minutos. Sin compromiso, solo soluciones reales para tus desafíos de Software y IA.
          </p>
          <ul class="mt-12 space-y-6 text-gray-300">
            <li class="flex items-center">
              <div class="w-8 h-8 bg-purple-600/20 rounded-lg flex items-center justify-center mr-4">
                <Icon name="check" size={16} class="text-purple-500" />
              </div>
              <span class="font-bold text-sm sm:text-base">Análisis de arquitectura y viabilidad técnica</span>
            </li>
            <li class="flex items-center">
              <div class="w-8 h-8 bg-purple-600/20 rounded-lg flex items-center justify-center mr-4">
                <Icon name="check" size={16} class="text-purple-500" />
              </div>
              <span class="font-bold text-sm sm:text-base">Estrategia de integración de Agentes de IA</span>
            </li>
            <li class="flex items-center">
              <div class="w-8 h-8 bg-purple-600/20 rounded-lg flex items-center justify-center mr-4">
                <Icon name="check" size={16} class="text-purple-500" />
              </div>
              <span class="font-bold text-sm sm:text-base">Roadmap de escalabilidad para plataformas SaaS</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="relative pb-16 px-8 sm:pb-24 sm:px-16 lg:py-24 lg:px-20 lg:pb-32 bg-gray-800/50 backdrop-blur-sm border-l border-gray-800">
        <div class="relative">
          <form action="#" method="POST" class="mt-6 grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-8">
            <div class="sm:col-span-2">
              <label for="name" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Nombre completo</label>
              <input type="text" name="name" id="name" autocomplete="name" required class="py-4 px-6 block w-full bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent rounded-2xl transition-all" placeholder="Tu nombre">
            </div>
            <div class="sm:col-span-2">
              <label for="email" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Correo corporativo</label>
              <input type="email" name="email" id="email" autocomplete="email" required class="py-4 px-6 block w-full bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent rounded-2xl transition-all" placeholder="nombre@empresa.com">
            </div>
            <div class="sm:col-span-2">
              <label for="message" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">¿Cómo podemos ayudarte?</label>
              <textarea id="message" name="message" rows="4" required class="py-4 px-6 block w-full bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent rounded-2xl transition-all" placeholder="Describe tu proyecto o necesidad..."></textarea>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="w-full inline-flex items-center justify-center px-8 py-5 border border-transparent rounded-2xl shadow-xl text-lg font-black text-white bg-gradient-to-r from-purple-600 to-indigo-600 hover:scale-[1.02] transition-all duration-300">
                Solicitar Consultoría
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative background pulse -->
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-purple-600/10 rounded-full blur-[120px]"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-indigo-600/10 rounded-full blur-[120px]"></div>
</section>


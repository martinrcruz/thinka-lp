---
import Icon from "./Icon.astro";
const { logoSrc = "/assets/images/icono thinka sin fondo.png" } = Astro.props;
---

<footer class="bg-brand-obsidian pt-24 pb-12 border-t border-white/5" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-8">
          <img src="/assets/images/icono thinka sin fondo.png" alt="Thinka Icon" class="h-8 w-auto brightness-0 invert" />
          <span class="text-xl font-black tracking-tighter text-brand-white uppercase">THINKA</span>
        </a>
        <p class="text-brand-slate leading-relaxed mb-8">
          IA administrada para empresas chilenas. Transformamos procesos complejos en flujos eficientes impulsados por inteligencia artificial privada.
        </p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/company/thinka-cl/" aria-label="LinkedIn" class="h-10 w-10 rounded-full bg-white/5 flex items-center justify-center text-brand-slate hover:text-brand-primary hover:bg-white/10 transition-all">
            <Icon name="linkedin" size={20} />
          </a>
          <a href="https://www.instagram.com/thinka.cl/" aria-label="Instagram" class="h-10 w-10 rounded-full bg-white/5 flex items-center justify-center text-brand-slate hover:text-brand-primary hover:bg-white/10 transition-all">
            <Icon name="instagram" size={20} />
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-brand-white font-bold mb-6">Soluciones</h3>
        <ul class="space-y-4 text-brand-slate text-sm">
          <li><a href="#soluciones" class="hover:text-brand-primary transition-colors">Asistente Interno</a></li>
          <li><a href="#soluciones" class="hover:text-brand-primary transition-colors">Soporte Omnicanal</a></li>
          <li><a href="#soluciones" class="hover:text-brand-primary transition-colors">Automatización de Emails</a></li>
          <li><a href="#soluciones" class="hover:text-brand-primary transition-colors">Análisis de Datos IA</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-brand-white font-bold mb-6">Empresa</h3>
        <ul class="space-y-4 text-brand-slate text-sm">
          <li><a href="/nosotros" class="hover:text-brand-primary transition-colors">Sobre Nosotros</a></li>
          <li><a href="#roi" class="hover:text-brand-primary transition-colors">Calculadora ROI</a></li>
          <li><a href="#planes" class="hover:text-brand-primary transition-colors">Planes Managed</a></li>
          <li><a href="/contacto" class="hover:text-brand-primary transition-colors">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-brand-white font-bold mb-6">Ubicación & Contacto</h3>
        <ul class="space-y-4 text-brand-slate text-sm">
          <li class="flex items-center gap-3">
            <Icon name="map-pin" size={16} class="text-brand-primary" />
            La Serena, Región de Coquimbo, Chile
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mail" size={16} class="text-brand-primary" />
            contacto@thinka.cl
          </li>
          <li class="flex items-center gap-3">
            <Icon name="whatsapp" size={16} class="text-brand-primary" />
            +56 9 8184 3411
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-brand-slate text-xs">
        &copy; {new Date().getFullYear()} Thinka IA Administrada. Todos los derechos reservados.
      </p>
      <div class="flex gap-6 text-xs text-brand-slate">
        <a href="/politica-privacidad" class="hover:text-brand-white transition-colors">Privacidad</a>
        <a href="/terminos-condiciones" class="hover:text-brand-white transition-colors">Términos</a>
        <a href="/aviso-legal" class="hover:text-brand-white transition-colors">Legal</a>
      </div>
    </div>
  </div>
</footer>

---
import Icon from "./Icon.astro";
const { logoSrc = "/assets/images/logo-thinka.png" } = Astro.props;
---
<!-- Footer -->
<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <div class="footer-logo">
          <img src={logoSrc} alt="Thinka Logo" width="120" height="40">
        </div>
        <p class="footer-description" data-translate="footer-description">
          <slot name="description">
            Soluciones de software inteligentes que transforman tu negocio a través de la innovación tecnológica.
          </slot>
        </p>
      </div>

      <div class="footer-section">
        <slot name="services-col">
          <h3 class="footer-title" data-translate="footer-services">Servicios</h3>
          <ul class="footer-links">
            <li><a href="#services">Software a Medida</a></li>
            <li><a href="#services">Plataformas SaaS</a></li>
            <li><a href="#services">Inteligencia Artificial</a></li>
            <li><a href="#services">Consultoría Digital</a></li>
          </ul>
        </slot>
      </div>

      <div class="footer-section">
        <slot name="company-col">
          <h3 class="footer-title" data-translate="footer-company">Empresa</h3>
          <ul class="footer-links">
            <li><a href="#about" data-translate="nav-nosotros">Nosotros</a></li>
            <li><a href="#portfolio" data-translate="nav-portafolio">Portafolio</a></li>
            <li><a href="#testimonials" data-translate="nav-testimonios">Testimonios</a></li>
            <li><a href="#contact" data-translate="nav-contacto">Contacto</a></li>
            <li><a href="#careers">Carreras</a></li>
          </ul>
        </slot>
      </div>

      <div class="footer-section">
        <h3 class="footer-title" data-translate="footer-follow">Síguenos</h3>
        <div class="social-links">
          <a href="https://www.linkedin.com/company/thinka-cl/" aria-label="LinkedIn" class="social-link" target="_blank" rel="noopener noreferrer">
            <Icon name="linkedin" size={24} />
          </a>
          <a href="https://www.instagram.com/thinka.cl/" aria-label="Instagram" class="social-link" target="_blank" rel="noopener noreferrer">
            <Icon name="instagram" size={24} />
          </a>
          <a href="https://www.facebook.com/people/Thinka-Desarrollo-de-Software-con-IA/61580902276921/" aria-label="Facebook" class="social-link" target="_blank" rel="noopener noreferrer">
            <Icon name="facebook" size={24} />
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2025 Thinka. <span data-translate="footer-rights">Todos los derechos reservados.</span></p>
      <div class="footer-legal">
        <a href="/politica-privacidad">Privacidad</a>
        <a href="/terminos-condiciones">Términos</a>
        <a href="/aviso-legal">Aviso Legal</a>
      </div>
    </div>
  </div>
</footer>

---
import CTAButton from './CTAButton.astro';

interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  color: string;
  isPopular?: boolean;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  name, 
  price, 
  description, 
  features, 
  color,
  isPopular = false,
  ctaText = "Comenzar ahora",
  ctaHref = "#contacto"
} = Astro.props;
---

<div 
  class:list={[
    "relative flex flex-col p-6 rounded-[32px] border transition-all duration-700 backdrop-blur-md overflow-hidden group",
    isPopular 
      ? "bg-brand-navy border-[var(--plan-color)]/40 shadow-glow scale-105 z-10" 
      : "bg-brand-navy/30 border-white/5 hover:border-[var(--plan-color)]/30 hover:bg-brand-navy/50"
  ]}
  style={`--plan-color: ${color};`}
>
  <!-- Blueprint Corner Detail -->
  <div class="absolute top-0 right-0 p-4 text-[8px] font-mono text-white/10 group-hover:text-[var(--plan-color)]/40 transition-colors pointer-events-none">
    0x{Math.random().toString(16).slice(2, 6).toUpperCase()}
  </div>

  {isPopular && (
    <div 
      class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 text-brand-obsidian text-[10px] font-black rounded-full uppercase tracking-[0.2em] shadow-lg"
      style={`background-color: ${color}; box-shadow: 0 0 20px ${color}66;`}
    >
      Plan Destacado
    </div>
  )}

  <div class="mb-8">
    <h3 class="text-xl font-bold mb-2 group-hover:text-[var(--plan-color)] transition-colors">{name}</h3>
    <p class="text-brand-slate text-xs leading-relaxed">{description}</p>
  </div>

  <div class="mb-8">
    <div class="flex items-baseline gap-1">
      <span class="text-3xl font-black tracking-tighter text-brand-white">{price}</span>
      {price !== 'Custom' && price !== 'A cotizar' && <span class="text-brand-slate text-[10px] font-mono">/INVERSIÓN_MENSUAL</span>}
    </div>
  </div>

  <ul class="space-y-3 mb-8 flex-grow">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-xs text-brand-white/70 group-hover:text-brand-white/90 transition-colors">
        <svg 
          class="h-4 w-4 shrink-0 opacity-70 group-hover:opacity-100 transition-opacity" 
          fill="none" 
          viewBox="0 0 24 24" 
          stroke={color}
          style={`color: ${color};`}
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
        </svg>
        {feature}
      </li>
    ))}
  </ul>

  <CTAButton 
    href={ctaHref} 
    variant={isPopular ? 'primary' : 'outline'} 
    class={`w-full text-sm py-3 ${isPopular ? 'shadow-lg' : ''}`}
    style={isPopular ? `background-color: ${color}; border-color: ${color}; box-shadow: 0 4px 15px ${color}44;` : `border-color: ${color}44; color: white;`}
  >
    {ctaText}
  </CTAButton>
</div>

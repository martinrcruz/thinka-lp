---
import Icon from "./Icon.astro";

const services = [
  {
    title: "Reducción de Trabajo Manual",
    description: "Automatizamos tareas repetitivas como responder preguntas frecuentes, clasificar correos, generar resúmenes, preparar reportes y hacer seguimiento de clientes o casos.",
    icon: "check",
    href: "#",
    keywords: ["Ahorro de Tiempo", "Menos Tareas Repetitivas", "Eficiencia"],
    gradient: "from-purple-500/20 to-indigo-500/20"
  },
  {
    title: "Mejor Uso de Información",
    description: "Transformamos documentos, correos y archivos dispersos en bases consultables. Tu equipo puede preguntar y recibir respuestas basadas en información real de la empresa.",
    icon: "code",
    href: "#",
    keywords: ["Búsqueda Inteligente", "Documentos Consultables", "Contexto Real"],
    gradient: "from-indigo-500/20 to-blue-500/20"
  },
  {
    title: "Respuesta Más Rápida",
    description: "Atención 24/7 a clientes y equipos internos. Respuestas iniciales a consultas frecuentes, derivación inteligente y reducción de tiempos de espera.",
    icon: "activity",
    href: "#",
    keywords: ["Atención 24/7", "Respuesta Inmediata", "Derivación Inteligente"],
    gradient: "from-blue-500/20 to-cyan-500/20"
  },
  {
    title: "Servicio Administrado",
    description: "Thinka se encarga del diseño, implementación, configuración, soporte, monitoreo, seguridad y mejora continua. Tú te enfocas en tu negocio.",
    icon: "shield",
    href: "#",
    keywords: ["Sin Complejidad", "Soporte Continuo", "Mejora Constante"],
    gradient: "from-cyan-500/20 to-teal-500/20"
  }
];
---

<section id="services" class="py-24 relative overflow-hidden bg-gray-50 dark:bg-gray-800/50">
  <!-- Subtle background decoration -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(139,92,246,0.05),transparent_70%)] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-20">
      <h2 class="text-base text-purple-600 font-bold tracking-widest uppercase mb-4">Beneficios</h2>
      <p class="text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-[1.2]">
        Resultados que sí <span class="bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent italic pb-2 -mb-2 pr-4">importan</span>
      </p>
      <p class="mt-6 text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
        No vendemos tecnología. Entregamos resultados operativos: menos tareas manuales, mejor atención y procesos más ordenados.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
      {services.map((service) => (
        <a href={service.href} class="group block relative bg-white dark:bg-gray-900 rounded-[3rem] p-10 border border-gray-100 dark:border-gray-800 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 overflow-hidden">
          {/* Background Gradient Hover Effect */}
          <div class={`absolute inset-0 bg-gradient-to-br ${service.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
          
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
              <div class="flex items-center justify-center h-16 w-16 rounded-2xl bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 group-hover:scale-110 group-hover:bg-purple-600 group-hover:text-white transition-all duration-300">
                <Icon name={service.icon as any} size={32} />
              </div>
              <div class="opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-4 group-hover:translate-x-0">
                <Icon name="arrow-right" size={24} class="text-purple-600 dark:text-purple-400" />
              </div>
            </div>

            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">
              {service.title}
            </h3>
            <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-8">
              {service.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {service.keywords.map((keyword) => (
                <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-100 dark:border-gray-700 group-hover:border-purple-200 dark:group-hover:border-purple-800 transition-colors">
                  {keyword}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

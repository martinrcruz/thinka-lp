---
const services = [
  {
    title: "Automatización de Procesos con IA",
    description: "Maximiza el ROI y ahorra tiempo automatizando tareas repetitivas. Implementamos agentes autónomos que trabajan 24/7 para tu negocio.",
    icon: "Cpu",
    keywords: ["Automatización", "ROI", "Eficiencia"]
  },
  {
    title: "Consultoría e Implementación",
    description: "Estrategia personalizada para la transformación digital con IA. Te guiamos desde la conceptualización hasta la puesta en marcha.",
    icon: "Briefcase",
    keywords: ["Consultoría IA", "Estrategia", "Transformación Digital"]
  },
  {
    title: "Eficiencia de Tokens y Costos",
    description: "Reducimos tu factura de API de OpenAI/Anthropic hasta un 70%. Optimizamos prompts y arquitecturas para soluciones token-efficient.",
    icon: "TrendingDown",
    keywords: ["Optimización de costos de IA", "Ahorro API", "Token-Efficient"]
  },
  {
    title: "Desarrollo de Software con IA",
    description: "Desarrollo ágil y escalable de aplicaciones potenciadas por Inteligencia Artificial. Software a medida que evoluciona con tu empresa.",
    icon: "Code",
    keywords: ["Desarrollo Software", "Apps IA", "Scalability"]
  }
];

---

<section id="services" class="py-20 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-base text-purple-600 font-semibold tracking-wide uppercase">Nuestros Servicios</h2>
      <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Soluciones Tecnológicas de Alto Impacto
      </p>
      <p class="mt-4 max-w-2xl text-xl text-gray-500 dark:text-gray-300 mx-auto">
        Impulsamos la innovación en empresas de Chile con servicios especializados en IA y desarrollo de software.
      </p>
    </div>

    <div class="mt-16">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => (
          <div class="bg-white dark:bg-gray-900 overflow-hidden shadow rounded-lg hover:shadow-xl transition-shadow duration-300 border border-gray-100 dark:border-gray-700 group">
            <div class="p-6">
              <div class="flex items-center justify-center h-12 w-12 rounded-md bg-purple-500 text-white mb-4 group-hover:bg-purple-600 transition-colors">
                <!-- Simple SVG Icon Placeholder based on service.icon -->
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">{service.title}</h3>
              <p class="mt-2 text-base text-gray-500 dark:text-gray-400 h-24 overflow-hidden">
                {service.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {service.keywords.map((keyword) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
                    {keyword}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

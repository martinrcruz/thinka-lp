---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thinka Seguridad | Ciberseguridad Empresarial" description="Protege tus activos digitales con las soluciones de ciberseguridad avanzada de Thinka. Auditoría, pentesting y protección continua.">
  <Header>
    <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="#services" class="nav-link">Servicios</a></li>
        <li><a href="#compliance" class="nav-link">Compliance</a></li>
         <li><a href="#contact" class="nav-link">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
     <section id="home" class="hero" aria-labelledby="hero-title">
        <div class="hero-background">
            <div class="hero-gradient"></div>
            <div class="hero-pattern"></div>
        </div>
        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                   <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <span>Ciberseguridad</span>
                </div>
                <h1 id="hero-title" class="hero-title">
                    <span class="hero-title-main">Thinka Seguridad</span>
                    <span class="hero-title-highlight">Protección Total</span>
                    <span class="hero-title-sub">Para tu Infraestructura Digital</span>
                </h1>
                <p class="hero-description">
                    Asegura la continuidad de tu negocio. Implementamos estándares internacionales de seguridad, pruebas de penetración y monitoreo continuo para blindar tus sistemas.
                </p>
                <div class="hero-actions">
                    <a href="#contact" class="btn btn-primary btn-hero">
                        <span>Solicitar Auditoría</span>
                         <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                    </a>
                </div>
            </div>
             <div class="hero-visual">
                <div class="hero-animation">
                     <div class="code-window">
                        <div class="window-header">
                             <div class="window-title">Security-Scan.sh</div>
                        </div>
                        <div class="code-content">
                             <div class="code-line">
                                <span class="line-number">1</span>
                                <span class="code-text"><span class="comment"># Vulnerability Assessment</span></span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">2</span>
                                <span class="code-text">Target: 192.168.1.X</span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">3</span>
                                <span class="code-text"><span class="string">SCANNING PORTS...</span> [OK]</span>
                            </div>
                             <div class="code-line typing">
                                <span class="line-number">4</span>
                                <span class="code-text"><span class="string">CHECKING SSL...</span> [SECURE]</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="services">
        <div class="container">
             <div class="section-header">
                <h2 class="section-title">Defensa en Profundidad</h2>
            </div>
            <div class="services-grid">
                <div class="service-card featured-service">
                    <h3 class="service-title">Pentesting y Auditoría</h3>
                    <p class="service-description">Simulamos ataques reales para identificar vulnerabilidades antes que los ciberdelincuentes.</p>
                </div>
                 <div class="service-card">
                    <h3 class="service-title">Hardening de Infraestructura</h3>
                    <p class="service-description">Aseguramos tus servidores, nubes y redes con las mejores prácticas del mercado.</p>
                </div>
                 <div class="service-card">
                    <h3 class="service-title">Cumplimiento Normativo</h3>
                    <p class="service-description">Te ayudamos a cumplir con normativas de protección de datos (GDPR, ISO 27001).</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="contact">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">No Esperes a ser Vulnerado</h2>
                <a href="mailto:seguridad@thinka.cl" class="btn btn-primary btn-lg">Evaluación Gratuita</a>
            </div>
        </div>
    </section>
  </main>

  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SimpleFooter from '../components/SimpleFooter.astro';
import Icon from '../components/Icon.astro';

const contactMethods = [
  {
    title: "Correo Electrónico",
    value: "contacto@thinka.cl",
    href: "mailto:contacto@thinka.cl",
    icon: "mail",
    color: "bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400"
  },
  {
    title: "WhatsApp Directo",
    value: "+56 9 8184 3411",
    href: "https://wa.me/56981843411",
    icon: "whatsapp",
    color: "bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400"
  },
  {
    title: "Ubicación",
    value: "Santiago, Chile",
    href: "#",
    icon: "map-pin",
    color: "bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400"
  }
];
---

<Layout 
  title="Contacto | Thinka"
  description="¿Tienes un proyecto en mente? Ponte en contacto con nosotros y hablemos sobre cómo podemos ayudarte con software e inteligencia artificial."
>
  <Navbar />
  
  <main class="bg-gray-50/50 dark:bg-gray-950/20 min-h-screen">
    <section class="py-20 lg:py-32">
      <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
        <div class="grid lg:grid-cols-2 gap-20 items-start">
          <!-- Text Content -->
          <div>
            <h1 class="text-5xl lg:text-7xl font-black text-gray-900 dark:text-white mb-8 leading-tight tracking-tight">
              Hablemos de <br/>
              <span class="bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent italic pr-4 py-2" style="box-decoration-break: clone; -webkit-box-decoration-break: clone;">tu próximo gran proyecto</span>
            </h1>
            <p class="text-xl text-gray-600 dark:text-gray-400 mb-12 leading-relaxed font-medium">
              Estamos listos para escucharte. Ya sea una consulta técnica, una idea de negocio o una solicitud de cotización, nuestro equipo responderá en menos de 24 horas hábiles.
            </p>

            <div class="grid gap-6">
              {contactMethods.map(method => (
                <a href={method.href} class="flex items-center p-6 bg-white dark:bg-gray-900 rounded-3xl border border-gray-100 dark:border-gray-800 shadow-sm hover:shadow-md transition-all group">
                  <div class={`w-14 h-14 rounded-2xl ${method.color} flex items-center justify-center mr-6 group-hover:scale-110 transition-transform`}>
                    <Icon name={method.icon as any} size={28} />
                  </div>
                  <div>
                    <p class="text-sm font-black text-gray-400 uppercase tracking-widest mb-1">{method.title}</p>
                    <p class="text-xl font-bold text-gray-900 dark:text-white">{method.value}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Contact Form (Placeholder) -->
          <div class="bg-white dark:bg-gray-900 rounded-[2.5rem] p-8 sm:p-12 border border-gray-100 dark:border-gray-800 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/5 rounded-full blur-3xl"></div>
            
            <form class="space-y-6 relative z-10">
              <div class="grid sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-sm font-bold text-gray-700 dark:text-gray-300 ml-1">Nombre</label>
                  <input type="text" placeholder="Ej: Juan Pérez" class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent focus:border-purple-500 outline-none transition-all dark:text-white" required />
                </div>
                <div class="space-y-2">
                  <label class="text-sm font-bold text-gray-700 dark:text-gray-300 ml-1">Empresa</label>
                  <input type="text" placeholder="Ej: Thinka SpA" class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent focus:border-purple-500 outline-none transition-all dark:text-white" />
                </div>
              </div>
              
              <div class="space-y-2">
                <label class="text-sm font-bold text-gray-700 dark:text-gray-300 ml-1">Correo Corporativo</label>
                <input type="email" placeholder="nombre@empresa.com" class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent focus:border-purple-500 outline-none transition-all dark:text-white" required />
              </div>

              <div class="space-y-2">
                <label class="text-sm font-bold text-gray-700 dark:text-gray-300 ml-1">Mensaje</label>
                <textarea rows="4" placeholder="¿En qué podemos ayudarte?" class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent focus:border-purple-500 outline-none transition-all dark:text-white resize-none" required></textarea>
              </div>

              <button type="submit" class="w-full py-5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-black rounded-2xl shadow-xl hover:shadow-purple-500/20 hover:-translate-y-1 transition-all active:scale-95">
                Enviar Mensaje
              </button>
              
              <p class="text-center text-xs text-gray-400 mt-6">
                Al enviar este formulario, aceptas nuestra <a href="/politica-privacidad" class="text-purple-600 font-bold hover:underline">Política de Privacidad</a>.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SimpleFooter />
</Layout>

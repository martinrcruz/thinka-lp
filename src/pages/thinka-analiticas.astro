---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thinka Analíticas | Dashboards Inteligentes" description="Visualiza y predice el futuro de tu negocio con Dashboards potenciados por IA. Toma decisiones basadas en datos reales.">
  <Header>
    <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="#features" class="nav-link">Funcionalidades</a></li>
        <li><a href="#solutions" class="nav-link">Soluciones</a></li>
        <li><a href="#contact" class="nav-link">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
    <section id="home" class="hero" aria-labelledby="hero-title">
        <div class="hero-background">
            <div class="hero-gradient"></div>
            <div class="hero-pattern"></div>
        </div>
        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                   <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="20" x2="18" y2="10"></line>
                      <line x1="12" y1="20" x2="12" y2="4"></line>
                      <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                    <span>Business Intelligence</span>
                </div>
                <h1 id="hero-title" class="hero-title">
                    <span class="hero-title-main">Thinka Analíticas</span>
                    <span class="hero-title-highlight">Datos que Impulsan</span>
                    <span class="hero-title-sub">Decisiones Estratégicas</span>
                </h1>
                <p class="hero-description">
                    Transforma tus datos en conocimiento accionable. Dashboards en tiempo real, análisis predictivo y reportes automatizados diseñados para la alta gerencia.
                </p>
                <div class="hero-actions">
                    <a href="#contact" class="btn btn-primary btn-hero">
                        <span>Ver Demo</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </a>
                </div>
            </div>
             <div class="hero-visual">
                <div class="hero-animation">
                     <div class="code-window">
                        <div class="window-header">
                            <div class="window-title">Analytics.py</div>
                        </div>
                        <div class="code-content">
                             <div class="code-line">
                                <span class="line-number">1</span>
                                <span class="code-text"><span class="comment"># Predict next month sales</span></span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">2</span>
                                <span class="code-text">model = <span class="class">ARIMA</span>(sales_data)</span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">3</span>
                                <span class="code-text">forecast = model.predict(steps=30)</span>
                            </div>
                            <div class="code-line typing">
                                <span class="line-number">4</span>
                                <span class="code-text"><span class="keyword">return</span> forecast</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="services">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Inteligencia de Negocios Real</h2>
                <p class="section-description">Más que gráficos bonitos, ofrecemos insights profundos.</p>
            </div>
            <div class="services-grid">
                <div class="service-card featured-service">
                    <h3 class="service-title">Análisis Predictivo</h3>
                    <p class="service-description">Anticípate al mercado con modelos de IA que proyectan tendencias de ventas, stock y demanda.</p>
                </div>
                <div class="service-card">
                    <h3 class="service-title">Tiempo Real</h3>
                    <p class="service-description">Monitorea tus KPIs críticos al segundo. Conexión directa a tus bases de datos y APIs.</p>
                </div>
                 <div class="service-card">
                    <h3 class="service-title">Multifuente</h3>
                    <p class="service-description">Unificamos datos de CRM, ERP, Marketing y Redes Sociales en una sola vista de verdad.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="contact">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Toma el Control de tus Datos</h2>
                <a href="mailto:contacto@thinka.cl" class="btn btn-primary btn-lg">Contactar Experto en Datos</a>
            </div>
        </div>
    </section>
  </main>
  
  <Footer />
</Layout>

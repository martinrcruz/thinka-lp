<script is:inline>
    // Plan to Volume Mapping
    const planToVolume = {
        'inicial': '0-2000',
        'pyme': '2000-10000',
        'empresa': '10000-25000',
        'corporativo': '25000-60000',
        'enterprise': '60000+'
    };

    // Volume to Plan Mapping
    const volumeToPlan = {
        '0-2000': 'inicial',
        '2000-10000': 'pyme',
        '10000-25000': 'empresa',
        '25000-60000': 'corporativo',
        '60000+': 'enterprise'
    };

    function selectPlan(planValue) {
        const planSelect = document.getElementById('plan');
        const volumeSelect = document.getElementById('volume');
        
        if (planSelect) {
            planSelect.value = planValue;
            
            // Auto-select corresponding volume
            if (volumeSelect && planToVolume[planValue]) {
                volumeSelect.value = planToVolume[planValue];
            }

            // Focus the plan select to show user it changed
            setTimeout(() => {
                planSelect.focus();
            }, 100);
        }
    }

    // Setup Event Listeners when DOM is loaded
    document.addEventListener('DOMContentLoaded', () => {
        const planSelect = document.getElementById('plan');
        const volumeSelect = document.getElementById('volume');

        if (planSelect && volumeSelect) {
            // When Plan changes -> Update Volume
            planSelect.addEventListener('change', (e) => {
                const selectedPlan = e.target.value;
                if (planToVolume[selectedPlan]) {
                    volumeSelect.value = planToVolume[selectedPlan];
                }
            });

            // When Volume changes -> Update Plan
            volumeSelect.addEventListener('change', (e) => {
                const selectedVolume = e.target.value;
                if (volumeToPlan[selectedVolume]) {
                    planSelect.value = volumeToPlan[selectedVolume];
                }
            });
        }
    });
</script>

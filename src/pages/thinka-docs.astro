---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thinka Docs | Procesamiento Inteligente de Documentos" description="Thinka Docs: Plataforma de procesamiento de Documentos con Inteligencia Artificial. Sube, analiza, corrige y exporta documentos a Odoo y Excel automáticamente." favicon="/assets/logo/Full-logo-dark.png">
  <Header logoSrc="/assets/images/logo-docs.png" showSettings={false}>
    <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="#features" class="nav-link">Funcionalidades</a></li>
        <li><a href="#credits-model" class="nav-link">Precios</a></li>
        <li><a href="#process" class="nav-link">Cómo Funciona</a></li>
        <li><a href="#contact" class="nav-link">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
        <!-- Hero Section -->
        <section id="home" class="hero" aria-labelledby="hero-title">
            <div class="hero-background">
                <div class="hero-gradient"></div>
                <div class="hero-pattern"></div>
            </div>
            <div class="hero-container">
                <div class="hero-content">
                    <div class="hero-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        <span>Análisis Inteligente de Documentos</span>
                    </div>
                    <h1 id="hero-title" class="hero-title">
                        <span class="hero-title-main">Procesamiento de Documentos</span>
                        <span class="hero-title-highlight">Impulsado por IA</span>
                        <span class="hero-title-sub">Automatización Contable Inteligente</span>
                    </h1>
                    <p class="hero-description">
                        Gestiona el ciclo completo de tus documentos tributarios. Sube PDFs, extrae datos con
                        Inteligencia Artificial, valida la información y exporta directamente a Odoo, Excel o CSV en
                        segundos.
                    </p>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <div class="stat-number">AI</div>
                            <div class="stat-label">Análisis Cognitivo</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number">100%</div>
                            <div class="stat-label">Web & Cloud</div>
                        </div>
                        <!-- <div class="stat-item">
                            <div class="stat-number">ERP</div>
                            <div class="stat-label">Integración Nativa</div>
                        </div> -->
                    </div>
                    <div class="hero-actions">
                        <a href="#contact" class="btn btn-primary btn-hero">
                            <span>Solicitar Demo</span>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="m9 18 6-6-6-6" />
                            </svg>
                        </a>
                        <a href="#features" class="btn btn-secondary btn-hero">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                            <span>Ver Funcionalidades</span>
                        </a>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="hero-animation">
                        <div class="code-window">
                            <div class="window-header">
                                <div class="window-controls">
                                    <span class="control red"></span>
                                    <span class="control yellow"></span>
                                    <span class="control green"></span>
                                </div>
                                <div class="window-title">Process-Invoice.ts</div>
                            </div>
                            <div class="code-content">
                                <div class="code-line">
                                    <span class="line-number">1</span>
                                    <span class="code-text"><span class="keyword">async function</span> <span
                                            class="method">processInvoice</span>(pdf) {</span>
                                </div>
                                <div class="code-line">
                                    <span class="line-number">2</span>
                                    <span class="code-text"> <span class="keyword">const</span> data = <span
                                            class="keyword">await</span> <span class="class">OpenAI</span>.<span
                                            class="method">extract</span>(pdf);</span>
                                </div>
                                <div class="code-line">
                                    <span class="line-number">3</span>
                                    <span class="code-text"> <span class="comment">// Validating fields...</span></span>
                                </div>
                                <div class="code-line">
                                    <span class="line-number">4</span>
                                    <span class="code-text"> <span class="keyword">return</span> <span
                                            class="method">exportToOdoo</span>(data);</span>
                                </div>
                                <div class="code-line typing">
                                    <span class="line-number">5</span>
                                    <span class="code-text">}</span>
                                </div>
                            </div>
                        </div>
                        <div class="floating-elements">
                            <div class="floating-card ai-card">
                                <div class="card-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                    </svg>
                                </div>
                                <div class="card-title">Análisis PDF</div>
                                <div class="card-metric">Precisión OCR</div>
                            </div>
                            <div class="floating-card dashboard-card">
                                <div class="card-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </div>
                                <div class="card-title">Validación</div>
                                <div class="card-metric">Automática</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="services" aria-labelledby="features-title">
            <div class="services-background">
                <div class="services-pattern"></div>
            </div>
            <div class="container">
                <div class="section-header">
                    <div class="section-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                        </svg>
                        <span>Flujo de Trabajo</span>
                    </div>
                    <h2 id="features-title" class="section-title">Gestión Integral de Documentos</h2>
                    <p class="section-description">
                        Una plataforma diseñada para optimizar cada paso del proceso contable, desde la recepción del
                        documento hasta su contabilización en el ERP.
                    </p>
                </div>

                <div class="services-grid">
                    <!-- Feature 1: Carga y Almacenamiento -->
                    <div class="service-card featured-service" data-aos="fade-up">
                        <div class="service-header">
                            <div class="service-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                    <polyline points="17 8 12 3 7 8"></polyline>
                                    <line x1="12" y1="3" x2="12" y2="15"></line>
                                </svg>
                            </div>
                            <div class="service-badge">Paso 1</div>
                        </div>
                        <h3 class="service-title">Carga Masiva en la Nube</h3>
                        <p class="service-description">
                            Sube tus documentos PDF de forma individual o por lotes. Almacenamiento seguro en Digital
                            Ocean Spaces con validación automática de formato y tamaño.
                        </p>
                        <ul class="service-features">
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Drag & Drop Inteligente
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Procesamiento por Lotes
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Historial de Cargas
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Detección de Duplicados
                            </li>
                        </ul>
                    </div>

                    <!-- Feature 2: Análisis IA -->
                    <div class="service-card" data-aos="fade-up" data-aos-delay="100">
                        <div class="service-header">
                            <div class="service-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"></path>
                                    <path d="M12 16v-4"></path>
                                    <path d="M8 12h8"></path>
                                </svg>
                            </div>
                            <div class="service-badge">Paso 2</div>
                        </div>
                        <h3 class="service-title">Análisis Cognitivo con IA</h3>
                        <p class="service-description">
                            Procesamiento asíncrono utilizando potentes modelos de OpenAI para extraer y estructurar
                            datos complejos de cada factura automáticamente.
                        </p>
                        <ul class="service-features">
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Extracción de Emisor/Receptor
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Detalle de Líneas y Glosas
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Cálculo de Impuestos y Totales
                            </li>
                        </ul>
                    </div>

                    <!-- Feature 3: Revisión y Corrección -->
                    <div class="service-card" data-aos="fade-up" data-aos-delay="200">
                        <div class="service-header">
                            <div class="service-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </div>
                            <div class="service-badge">Paso 3</div>
                        </div>
                        <h3 class="service-title">Control de Calidad</h3>
                        <p class="service-description">
                            Interfaz intuitiva para revisar documentos procesados y corregir aquellas con alertas. Edición
                            completa de cabeceras y líneas de detalle.
                        </p>
                        <ul class="service-features">
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Validación Visual de Datos
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Alertas de Inconsistencias
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Edición Manual Asistida
                            </li>
                        </ul>
                    </div>

                    <!-- Feature 4: Exportación -->
                    <div class="service-card" data-aos="fade-up" data-aos-delay="200">
                        <div class="service-header">
                            <div class="service-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path
                                        d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                                    </path>
                                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                </svg>
                            </div>
                            <div class="service-badge">Paso 4</div>
                        </div>
                        <h3 class="service-title">Integración y Exportación</h3>
                        <p class="service-description">
                            Exporta tus datos limpios y estructurados. Compatible nativamente con Odoo 18 Enterprise y
                            formatos universales como Excel y CSV.
                        </p>
                        <ul class="service-features">
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Conector Odoo 18 Directo
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Exportación a Excel (XLSX)
                            </li>
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Archivos CSV Estándar
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Credit Model Section -->
        <section id="credits-model" class="credits-section" aria-labelledby="credits-title">
            <div class="container">
                <div class="section-header">
                     <div class="section-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="16"></line>
                            <line x1="8" y1="12" x2="16" y2="12"></line>
                        </svg>
                        <span>Modelo de Créditos</span>
                    </div>
                    <h2 id="credits-title" class="section-title">Precios Flexibles y Transparentes</h2>
                    <p class="section-description">
                        Sin suscripciones fijas. Paga solo por el valor real que consumes. Los créditos funcionan como moneda interna.
                    </p>
                </div>

                    <!-- Pricing Cards Grid -->
                    <div class="pricing-container">
                        <h3 class="pricing-title-block gradient-text">Paquetes de Créditos Disponibles</h3>
                        
                        <div class="pricing-cards-grid">
                            <!-- Card 1: Inicial -->
                            <div class="pricing-card">
                                <div class="card-header">
                                    <h4 class="plan-name">Inicial</h4>
                                    <div class="plan-credits">2.000 Créditos</div>
                                </div>
                                <div class="card-price">
                                    <span class="currency">USD</span>
                                    <span class="amount">99</span>
                                </div>
                                <div class="card-meta">
                                    <span class="unit-price">USD 0,0495 / crédito</span>
                                </div>
                                
                                <ul class="feature-list">
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-green-500 rounded-full bg-green-100 p-1" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Hasta <strong>2.000</strong> Facturas</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Procesamiento 24/7</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Soporte vía Email</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>API Rest Estándar</span>
                                    </li>
                                </ul>

                                <div class="card-action">
                                    <a href="#contact" class="btn-plan" onclick="selectPlan('inicial')">Elegir Plan</a>
                                </div>
                            </div>

                            <!-- Card 2: Pyme -->
                            <div class="pricing-card">
                                <div class="card-header">
                                    <h4 class="plan-name">Pyme</h4>
                                    <div class="plan-credits">10.000 Créditos</div>
                                </div>
                                <div class="card-price">
                                    <span class="currency">USD</span>
                                    <span class="amount">399</span>
                                </div>
                                <div class="card-meta">
                                    <span class="unit-price">USD 0,0399 / crédito</span>
                                </div>
                                
                                <ul class="feature-list">
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Hasta <strong>10.000</strong> Facturas</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Tablas Complejas</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Soporte Prioritario</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Dashboard Avanzado</span>
                                    </li>
                                </ul>

                                <div class="card-action">
                                    <a href="#contact" class="btn-plan" onclick="selectPlan('pyme')">Elegir Plan</a>
                                </div>
                            </div>

                            <!-- Card 3: Empresa (Popular) -->
                            <div class="pricing-card popular-card">
                                <div class="popular-badge">Más Popular</div>
                                <div class="card-header">
                                    <h4 class="plan-name">Empresa</h4>
                                    <div class="plan-credits">25.000 Créditos</div>
                                </div>
                                <div class="card-price">
                                    <span class="currency">USD</span>
                                    <span class="amount">899</span>
                                </div>
                                <div class="card-meta">
                                    <span class="unit-price">USD 0,0359 / crédito</span>
                                </div>
                                
                                <ul class="feature-list">
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Hasta <strong>25.000</strong> Docs</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Contratos y Legales</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Onboarding Asistido</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>SLA 99.9% Uptime</span>
                                    </li>
                                </ul>

                                <div class="card-action">
                                    <a href="#contact" class="btn-plan btn-popular" onclick="selectPlan('empresa')">Elegir Plan</a>
                                </div>
                            </div>

                            <!-- Card 4: Corporativo -->
                            <div class="pricing-card">
                                <div class="card-header">
                                    <h4 class="plan-name">Corporativo</h4>
                                    <div class="plan-credits">60.000 Créditos</div>
                                </div>
                                <div class="card-price">
                                    <span class="currency">USD</span>
                                    <span class="amount">1.999</span>
                                </div>
                                <div class="card-meta">
                                    <span class="unit-price">USD 0,0333 / crédito</span>
                                </div>
                                
                                <ul class="feature-list">
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Hasta <strong>60.000</strong> Docs</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Modelos a Medida</span>
                                    </li>
                                    <li class="feature-item">
                                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Account Manager</span>
                                    </li>

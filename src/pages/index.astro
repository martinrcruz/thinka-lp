---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thinka - Soluciones de Software con Inteligencia Artificial" favicon="/assets/logo/faviconThinka.png">
  <Header logoSrc="/assets/images/headerThinka.png" showSettings={false}>
    <ul class="nav-list">
      <li><a href="#home" class="nav-link" data-translate="nav-inicio">Inicio</a></li>
      <li><a href="#solutions" class="nav-link" data-translate="nav-soluciones">Soluciones</a></li>
      <li><a href="#services" class="nav-link" data-translate="nav-servicios">Servicios</a></li>
      <li><a href="#about" class="nav-link" data-translate="nav-nosotros">Nosotros</a></li>

      <li><a href="#testimonials" class="nav-link" data-translate="nav-testimonios">Testimonios</a></li>
      <li><a href="#contact" class="nav-link" data-translate="nav-contacto">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
    <!-- Hero Section -->
    <section id="home" class="hero" aria-labelledby="hero-title">
      <div class="hero-background">
        <div class="hero-gradient"></div>
        <div class="hero-pattern"></div>
      </div>
      <div class="hero-container">
        <div class="hero-content">
          <div class="hero-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
            </svg>
            <span data-translate="hero-badge">Tecnología de Vanguardia</span>
          </div>
          <h1 id="hero-title" class="hero-title">
            <span class="hero-title-main" data-translate="hero-title-main">Desarrollo de Software</span>
            <span class="hero-title-highlight" data-translate="hero-title-highlight">a Medida</span>
            <span class="hero-title-sub" data-translate="hero-title-sub">con Inteligencia Artificial</span>
          </h1>
          <p class="hero-description" data-translate="hero-description">
            Transformamos ideas en soluciones digitales inteligentes. Especializados en chatbots avanzados,
            aplicaciones web personalizadas y sistemas de automatización que revolucionan tu negocio.
          </p>
          <div class="hero-stats">
            <div class="stat-item">
              <div class="stat-number">150+</div>
              <div class="stat-label" data-translate="hero-stat-proyectos">Proyectos</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">98%</div>
              <div class="stat-label" data-translate="hero-stat-satisfaccion">Satisfacción</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">5+</div>
              <div class="stat-label" data-translate="hero-stat-anos">Años</div>
            </div>
          </div>
          <div class="hero-actions">
            <a href="#contact" class="btn btn-primary btn-hero">
              <span data-translate="hero-btn-comenzar">Comenzar Proyecto</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
            <a href="#portfolio" class="btn btn-secondary btn-hero">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="23 7 16 12 23 17 23 7" />
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2" />
              </svg>
              <span data-translate="hero-btn-demo">Ver Demo</span>
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-animation">
            <div class="code-window">
              <div class="window-header">
                <div class="window-controls">
                  <span class="control red"></span>
                  <span class="control yellow"></span>
                  <span class="control green"></span>
                </div>
                <div class="window-title">AI-ChatBot.java</div>
              </div>
              <div class="code-content">
                <div class="code-line">
                  <span class="line-number">1</span>
                  <span class="code-text"><span class="keyword">@Service</span></span>
                </div>
                <div class="code-line">
                  <span class="line-number">2</span>
                  <span class="code-text"><span class="keyword">public class</span> <span
                      class="class">ChatBotService</span> {</span>
                </div>
                <div class="code-line">
                  <span class="line-number">3</span>
                  <span class="code-text"> <span class="keyword">private</span> <span class="type">NLPProcessor</span>
                    nlp;</span>
                </div>
                <div class="code-line">
                  <span class="line-number">4</span>
                  <span class="code-text"> <span class="comment">// AI-powered response</span></span>
                </div>
                <div class="code-line typing">
                  <span class="line-number">5</span>
                  <span class="code-text"> <span class="keyword">public</span> <span class="type">Response</span> <span
                      class="method">process</span>()</span>
                </div>
              </div>
            </div>
            <div class="floating-elements">
              <div class="floating-card ai-card">
                <div class="card-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    <path d="M10 9h4" />
                    <path d="M10 13h4" />
                  </svg>
                </div>
                <div class="card-title">Chatbot IA</div>
                <div class="card-metric">95% precisión</div>
              </div>
              <div class="floating-card dashboard-card">
                <div class="card-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 3v18h18" />
                    <path d="M7 12l4-4 4 4 4-4" />
                  </svg>
                </div>
                <div class="card-title">Dashboard</div>
                <div class="card-metric">Tiempo real</div>
              </div>
              <div class="floating-card mobile-card">
                <div class="card-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                    <line x1="12" y1="18" x2="12.01" y2="18" />
                  </svg>
                </div>
                <div class="card-title">App Móvil</div>
                <div class="card-metric">Híbrida</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solutions Section -->
    <section id="solutions" class="solutions" aria-labelledby="solutions-title">
      <div class="container">
        <div class="section-header">
           <div class="section-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
            <span>Nuestras Soluciones</span>
          </div>
          <h2 id="solutions-title" class="section-title">Ecosistema Thinka</h2>
          <p class="section-description">
            Herramientas especializadas diseñadas para potenciar cada aspecto de tu organización con la fuerza de la IA.
          </p>
        </div>

        <div class="solutions-grid">
          <!-- Card 1: Thinka Negocio -->
          <a href="/thinka-negocios" class="solution-card card-business" data-aos="fade-up">
             <div class="solution-icon-wrapper">
              <div class="solution-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 21h18"/>
                  <path d="M5 21V7l8-4 8 4v14"/>
                  <path d="M17 21v-8.5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0-.5.5V21"/>
                  <path d="M11 21v-3.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5V21"/>
                </svg>
              </div>
            </div>
            <h3 class="solution-title">Thinka Negocio</h3>
            <p class="solution-desc">Soluciones integrales para la gestión empresarial. Automatiza flujos de trabajo y optimiza la toma de decisiones estratégicas.</p>
            <ul class="solution-features">
              <li>Dashboards en tiempo real</li>
              <li>Automatización de procesos</li>
              <li>Integración de sistemas</li>
            </ul>
             <span class="btn-link">Ver más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </a>

          <!-- Card 2: Thinka Documentos -->
          <a href="/thinka-docs" class="solution-card card-docs featured" data-aos="fade-up" data-aos-delay="100">
            <div class="solution-badge">Popular</div>
            <div class="solution-icon-wrapper">
              <div class="solution-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              </div>
            </div>
            <h3 class="solution-title">Thinka Documentos</h3>
            <p class="solution-desc">Procesamiento inteligente de documentos. Extrae, clasifica y analiza información de archivos PDF e imágenes automáticamente.</p>
            <ul class="solution-features">
              <li>Extracción de datos con IA</li>
              <li>Clasificación automática</li>
              <li>Búsqueda semántica</li>
            </ul>
             <span class="btn-link">Ver más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </a>

          <!-- Card 3: Thinka Asistente -->
          <a href="/thinka-asistente" class="solution-card card-assistant" data-aos="fade-up" data-aos-delay="200">
             <div class="solution-icon-wrapper">
              <div class="solution-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  <path d="M8 10h.01"></path>
                  <path d="M12 10h.01"></path>
                  <path d="M16 10h.01"></path>
                </svg>
              </div>
            </div>
            <h3 class="solution-title">Thinka Asistente</h3>
            <p class="solution-desc">Tu asistente virtual avanzado. Atiende clientes 24/7, agende reuniones y resuelve consultas con lenguaje natural.</p>
             <ul class="solution-features">
              <li>Atención 24/7</li>
              <li>Agendamiento inteligente</li>
              <li>Multicanal (Web, WhatsApp)</li>
            </ul>
             <span class="btn-link">Ver más <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
          </a>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services" aria-labelledby="services-title">
      <div class="services-background">
        <div class="services-pattern"></div>
      </div>
      <div class="container">
        <div class="section-header">
          <div class="section-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
            <span data-translate="services-badge">Servicios Especializados</span>
          </div>
          <h2 id="services-title" class="section-title" data-translate="services-title">Soluciones Tecnológicas de
            Vanguardia</h2>
          <p class="section-description" data-translate="services-description" style="margin-bottom: 3rem;">
            Desarrollamos software a medida integrando inteligencia artificial para transformar
            digitalmente tu empresa con soluciones escalables y de alto rendimiento.
          </p>
        </div>

        <div class="services-grid">
          <div class="service-card featured-service" data-aos="fade-up">
            <div class="service-header">
              <div class="service-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                  <circle cx="12" cy="11" r="1" />
                  <circle cx="8" cy="11" r="1" />
                  <circle cx="16" cy="11" r="1" />
                </svg>
              </div>
              <div class="service-badge">Especialidad</div>
            </div>
            <h3 class="service-title">Chatbots con IA Avanzada</h3>
            <p class="service-description">
              Asistentes virtuales inteligentes con procesamiento de lenguaje natural (NLP) avanzado e integración con
              LLM.
              Automatización de ventas, soporte con 99.9% de disponibilidad y análisis conversacional en tiempo real.
            </p>
            <div class="service-metrics">
              <div class="metric">
                <span class="metric-value">95%</span>
                <span class="metric-label">Precisión</span>
              </div>
              <div class="metric">
                <span class="metric-value" data-value="24/7">99.9%</span>
                <span class="metric-label">Disponibilidad</span>
              </div>
            </div>
            <ul class="service-features">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Procesamiento de Lenguaje Natural
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Integración Multi-canal (Web, WhatsApp, Telegram)
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Analytics y Métricas de Conversación
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Aprendizaje Automático Continuo
              </li>
            </ul>
            <div class="service-cta">
              <a href="#contact" class="btn btn-primary btn-service">Consultar Proyecto</a>
            </div>
          </div>

          <div class="service-card" data-aos="fade-up" data-aos-delay="100">
            <div class="service-header">
              <div class="service-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                </svg>
              </div>
            </div>
            <h3 class="service-title">Desarrollo de Software a Medida</h3>
            <p class="service-description">
              Aplicaciones web y sistemas empresariales desarrollados con Spring Boot, arquitectura de microservicios,
              Angular y despliegue en la nube.
            </p>
            <ul class="service-features">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Java + Spring Boot + Angular
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Arquitectura de Microservicios
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Cloud Native (AWS, Azure, GCP)
              </li>
            </ul>
            <div class="service-cta">
              <a href="#contact" class="btn btn-outline btn-service">Más Información</a>
            </div>
          </div>

          <div class="service-card" data-aos="fade-up" data-aos-delay="200">
            <div class="service-header">
              <div class="service-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                  <line x1="8" y1="21" x2="16" y2="21" />
                  <line x1="12" y1="17" x2="12" y2="21" />
                </svg>
              </div>
            </div>
            <h3 class="service-title">Dashboards Inteligentes</h3>
            <p class="service-description">
              Visualización de datos en tiempo real con análisis predictivo, alertas inteligentes y reportes
              automatizados para la toma de decisiones estratégicas.
            </p>
            <ul class="service-features">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Análisis Predictivo con IA
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Visualización Interactiva
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                Integración Multi-fuente
              </li>
            </ul>
            <div class="service-cta">
              <a href="#contact" class="btn btn-outline btn-service">Más Información</a>
            </div>
          </div>

       
        </div>

        <div class="services-cta">
          <div class="cta-content">
            <h3>¿No encuentras lo que buscas?</h3>
            <p>Desarrollamos soluciones personalizadas para cada necesidad empresarial</p>
            <a href="#contact" class="btn btn-primary btn-lg">Solicitar Cotización Personalizada</a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about" aria-labelledby="about-title">
      <div class="container">
        <div class="about-content">
          <div class="about-text" data-aos="fade-right">
            <h2 id="about-title" class="section-title" data-translate="about-title">¿Por qué Thinka?</h2>
            <p class="about-description">
              Thinka nace de la combinación perfecta entre "think" (pensar) y "tinca" (chilenismo que significa "te
              parece").
              Representa nuestra filosofía de pensar en la primera opción con calidad A para cada proyecto.
            </p>
            <p class="about-description">
              Nos especializamos en integrar inteligencia artificial y automatización en los procesos de nuestros
              clientes,
              utilizando tecnologías de vanguardia como Java con Spring Boot, microservicios y desarrollo en la nube.
            </p>

            <div class="tech-stack">
              <h3 class="tech-title" data-translate="tech-title">Nuestro Stack Tecnológico</h3>
              <div class="tech-tags">
                <span class="tech-tag">Java</span>
                <span class="tech-tag">Spring Boot</span>
                <span class="tech-tag">Microservicios</span>
                <span class="tech-tag">Cloud Native</span>
                <span class="tech-tag">Inteligencia Artificial</span>
                <span class="tech-tag">NLP</span>
                <span class="tech-tag">Chatbots</span>
                <span class="tech-tag">React Native</span>
                <span class="tech-tag">Node.js</span>
                <span class="tech-tag">Docker</span>
                <span class="tech-tag">Kubernetes</span>
              </div>
            </div>
          </div>

          <div class="about-visual" data-aos="fade-left">
            <div class="about-stats">
              <div class="stat-item">
                <div class="stat-number">50+</div>
                <div class="stat-label">Proyectos Completados</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">98%</div>
                <div class="stat-label">Satisfacción del Cliente</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">100</div>
                <div class="stat-label">Soporte Técnico</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">5+</div>
                <div class="stat-label">Años de Experiencia</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials" aria-labelledby="testimonials-title">
      <div class="container">
        <div class="section-header">
          <h2 id="testimonials-title" class="section-title" data-translate="testimonials-title">Lo que Dicen Nuestros
            Clientes</h2>
          <p class="section-description" data-translate="testimonials-description" style="margin-bottom: 3rem;">
            Descubre por qué las empresas confían en Thinka para transformar sus procesos con tecnología
          </p>
        </div>

        <div class="testimonials-grid">
          <div class="testimonial-card" data-aos="fade-up">
            <div class="testimonial-content">
              <div class="testimonial-rating">
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
              </div>
              <blockquote class="testimonial-text">
                "Thinka transformó completamente nuestro proceso de análisis de datos. El dashboard que desarrollaron
                nos permite tomar decisiones en tiempo real y ha aumentado nuestra eficiencia operativa en un 40%."
              </blockquote>
              <div class="testimonial-author">
                <div class="author-avatar">
                  <img src="/assets/images/testimonial-1.svg" alt="María González" loading="lazy">
                </div>
                <div class="author-info">
                  <h4 class="author-name">María González</h4>
                  <p class="author-title">Directora de Operaciones</p>
                  <p class="author-company">RetailTech Solutions</p>
                </div>
              </div>
            </div>
          </div>

          <div class="testimonial-card" data-aos="fade-up" data-aos-delay="100">
            <div class="testimonial-content">
              <div class="testimonial-rating">
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
                <span class="star">⭐</span>
              </div>
              <blockquote class="testimonial-text">
                "La aplicación móvil que Thinka desarrolló para nuestro servicio de delivery superó todas nuestras
                expectativas. La integración con IA para optimizar rutas nos ha reducido costos en un 25%."
              </blockquote>
              <div class="testimonial-author">
                <div class="author-avatar">
                  <img src="/assets/images/testimonial-2.svg" alt="Carlos Mendoza" loading="lazy">
                </div>
                <div class="author-info">
                  <h4 class="author-name">Carlos Mendoza</h4>
                  <p class="author-title">CEO & Fundador</p>
                  <p class="author-company">FastDelivery Chile</p>
                </div>
              </div>
            </div>
          </div>

          <div class="testimonial-card" data-aos="fade-up" data-aos-delay="200">
            <div class="testimonial-content">

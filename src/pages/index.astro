<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initGlobalAnimations = () => {
    // Reveal animation for cards and sections
    const revealElements = document.querySelectorAll('.reveal');
    
    revealElements.forEach((el) => {
      gsap.fromTo(el, 
        { 
          opacity: 0, 
          y: 30,
          scale: 0.95,
          filter: "blur(10px)"
        },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          filter: "blur(0px)",
          duration: 1,
          ease: "power3.out",
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none reverse"
          }
        }
      );
    });

    // Text Reveal (Masking effect) for headings
    const textReveals = document.querySelectorAll('.text-fluid-h2');
    textReveals.forEach((el) => {
      // Simple mask reveal effect using clip-path
      gsap.fromTo(el,
        {
          clipPath: "polygon(0 0, 0 0, 0 100%, 0% 100%)",
          x: -20
        },
        {
          clipPath: "polygon(0 0, 100% 0, 100% 100%, 0 100%)",
          x: 0,
          duration: 1.2,
          ease: "power3.out",
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
          }
        }
      );
    });

    // Magnetic Buttons
    const magneticButtons = document.querySelectorAll('.magnetic-btn');
    magneticButtons.forEach(btn => {
      if (!(btn instanceof HTMLElement)) return;
      
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        gsap.to(btn, {
          x: x * 0.2,
          y: y * 0.2,
          duration: 0.3,
          ease: "power2.out"
        });
      });
      
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.5,
          ease: "elastic.out(1, 0.3)"
        });
      });
    });
  };

  const stickyCta = document.getElementById('sticky-cta');
  let lastScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      stickyCta?.classList.remove('translate-y-full');
      stickyCta?.classList.add('translate-y-0');
    } else {
      stickyCta?.classList.remove('translate-y-0');
      stickyCta?.classList.add('translate-y-full');
    }
    lastScrollY = window.scrollY;
  });

  document.addEventListener("DOMContentLoaded", initGlobalAnimations);
  document.addEventListener("astro:page-load", initGlobalAnimations);
  // Process 3D icons to remove black background and make them truly transparent
  function processIcons() {
    const icons = document.querySelectorAll('.ai-3d-icon') as NodeListOf<HTMLImageElement>;
    
    icons.forEach(img => {
      if (img.dataset.processed) return;
      
      const process = () => {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        
        ctx.drawImage(img, 0, 0);
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;

        for (let i = 0; i < data.length; i += 4) {
          const r = data[i];
          const g = data[i+1];
          const b = data[i+2];
          
          // Calculate luminance/intensity
          // We use a slightly more aggressive threshold for "black" parts
          const intensity = Math.max(r, g, b);
          
          if (intensity < 40) {
            // Smoothly fade out dark pixels
            data[i+3] = Math.pow(intensity / 40, 2) * 255;
          }
          
          // If it's very dark, just make it transparent
          if (intensity < 5) {
            data[i+3] = 0;
          }
        }

        ctx.putImageData(imageData, 0, 0);
        img.src = canvas.toDataURL();
        img.dataset.processed = 'true';
        img.classList.remove('opacity-0');
        img.classList.add('opacity-100');
      };

      if (img.complete) {
        process();
      } else {
        img.onload = process;
      }
    });
  }

  processIcons();
  document.addEventListener('astro:after-swap', processIcons);
</script>


---
import Layout from '../layouts/Layout.astro';
import NavbarManaged from '../components/NavbarManaged.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SpotlightCard from '../components/SpotlightCard.astro';
import PlanCard from '../components/PlanCard.astro';
import ROICalculator from '../components/ROICalculator.astro';
import FAQItem from '../components/FAQItem.astro';
import CTAButton from '../components/CTAButton.astro';
import Footer from '../components/Footer.astro';
import DataChaosCanvas from '../components/3d/DataChaosCanvasWrapper.ts';
import OrchestratorCanvas from '../components/3d/OrchestratorCanvasWrapper.ts';

import DataProcessorCanvas from '../components/3d/DataProcessorCanvasWrapper.ts';
import NeuralCoreCanvas from '../components/3d/NeuralCoreCanvasWrapper.ts';

const useCases = [
  {
    title: "Asistente Interno Experto",
    description: "Toda la documentación y manuales de tu empresa consultables en segundos por tu equipo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
    span: "md:col-span-2",
    type: "knowledge" as const
  },
  {
    title: "Soporte Omnicanal 24/7",
    description: "Atención inmediata en WhatsApp, Web y Correo con el tono de tu marca.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01"/><path d="M12 10h.01"/><path d="M16 10h.01"/></svg>`,
    span: "md:col-span-1",
    type: "support" as const
  },
  {
    title: "Automatización de Correos",
    description: "Clasificación inteligente y redacción de borradores para que solo tengas que revisar y enviar.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    span: "md:col-span-1",
    type: "automation" as const
  },
  {
    title: "Análisis de Datos Proactivo",
    description: "Convierte planillas complejas en insights de negocio sin ser un experto en datos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    span: "md:col-span-2",
    type: "analytics" as const
  },
  {
    title: "Onboarding Inteligente",
    description: "Guía a tus nuevos clientes o empleados con procesos personalizados guiados por IA.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    span: "md:col-span-1",
    type: "onboarding" as const
  },
  {
    title: "Gestión Documental",
    description: "Búsqueda semántica en miles de archivos. Encuentra lo que necesitas por concepto, no por nombre.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><polyline points="14 2 14 8 20 8"/><path d="M3 15h6"/><path d="M3 18h6"/><path d="M3 12h6"/></svg>`,
    span: "md:col-span-1",
    type: "documents" as const
  }
];

const plans = [
  {
    name: "Starter",
    price: "$140.000",
    color: "#00ff94", // Cyan
    description: "PyMEs y validación de caso de uso inicial.",
    features: [
      "1 Workspace",
      "1 Asistente",
      "RAG Global Básico (50 docs)",
      "Reporte consolidado mensual"
    ]
  },
  {
    name: "Professional",
    price: "$320.000",
    color: "#3b82f6", // Blue
    description: "Empresas en crecimiento con operación diaria estructurada.",
    features: [
      "1 Workspace",
      "3 Asistentes",
      "RAG específico por chatbot (200 docs)",
      "Alertas de billing de uso"
    ]
  },
  {
    name: "Business",
    price: "$600.000",
    color: "#6366f1", // Indigo
    description: "Operaciones críticas y múltiples áreas internas.",
    isPopular: true,
    features: [
      "1 Workspace",
      "10 Asistentes",
      "RAG avanzado (1.000 docs)",
      "Auditoría central y local constante"
    ]
  },
  {
    name: "Enterprise",
    price: "$990.000",
    color: "#a855f7", // Purple
    description: "Corporativos con alta carga transaccional de IA.",
    features: [
      "1 Workspace",
      "20 Asistentes",
      "RAG por volumen de infraestructura",
      "Trazabilidad en tiempo real"
    ]
  },
  {
    name: "Custom",
    price: "A cotizar",
    color: "#f59e0b", // Amber
    description: "Instituciones con requerimientos específicos de hardware o seguridad.",
    features: [
      "A Medida",
      "A medida",
      "Integración completa de ecosistemas",
      "Exportación de logs y auditoría"
    ]
  }
];

const faqs = [
  {
    question: "¿En qué se diferencia de usar ChatGPT?",
    answer: "ChatGPT es una herramienta genérica. Thinka es un servicio administrado que utiliza tus datos privados bajo protocolos de seguridad empresarial, integrado con tus sistemas actuales y mantenido por expertos para que tú no tengas que aprender a programar prompts."
  },
  {
    question: "¿Mis datos están seguros?",
    answer: "Absolutamente. Utilizamos entornos aislados por cliente. Tus datos no se utilizan para entrenar modelos públicos y cumplimos con estándares de seguridad para el manejo de información corporativa sensible."
  },
  {
    question: "¿Cuánto tiempo toma la implementación?",
    answer: "Un asistente base puede estar listo en menos de 72 horas. Automatizaciones más complejas con integraciones de sistema suelen tomar entre 1 y 2 semanas."
  },
  {
    question: "¿Necesito conocimientos técnicos?",
    answer: "Ninguno. Somos un servicio administrado. Nosotros configuramos, entrenamos y mantenemos la IA por ti. Tu equipo solo interactúa con una herramienta fácil de usar."
  }
];
---

<Layout 
  title="Thinka IA Administrada | Automatización e Inteligencia para Empresas en Chile"
  description="Reduzca el trabajo manual y aumente la productividad con IA administrada. Implementamos asistentes inteligentes y automatizaciones a medida para su empresa."
>
  <NavbarManaged />

  <main id="main-content">
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex flex-col justify-center pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden bg-brand-obsidian">
      <!-- Minimalist Background Animation -->
      <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <!-- Glowing Orbs with increased opacity and adjusted blend modes for visibility against dark bg -->
        <div class="absolute top-[10%] left-[10%] w-[50vw] h-[50vw] max-w-[700px] max-h-[700px] bg-brand-primary/20 blur-[100px] rounded-full mix-blend-screen animate-blob"></div>
        <div class="absolute top-[30%] right-[5%] w-[45vw] h-[45vw] max-w-[600px] max-h-[600px] bg-brand-indigo/20 blur-[100px] rounded-full mix-blend-screen animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-[20%] left-[30%] w-[60vw] h-[60vw] max-w-[900px] max-h-[900px] bg-[#6366F1]/15 blur-[120px] rounded-full mix-blend-screen animate-blob animation-delay-4000"></div>
        
        <!-- Subtle grid overlay -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_50%,#000_80%,transparent_100%)]"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 flex-grow flex flex-col justify-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 mb-8 animate-fade-in">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"></span>
          </span>
          <span class="text-[10px] font-bold tracking-widest uppercase text-brand-primary">Sistemas de IA: Rendimiento Máximo</span>
        </div>
        
        <h1 class="text-fluid-h1 font-extrabold tracking-tight mb-8 leading-[1.1] text-gradient-white">
          Recupere el control de su tiempo con <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-indigo">IA Administrada</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-brand-slate max-w-3xl mx-auto mb-12 leading-relaxed">
          Libere a su equipo de las tareas repetitivas. Diseñamos e implementamos su <span class="text-brand-white">infraestructura de inteligencia</span> para que usted solo se preocupe de escalar.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <CTAButton href="#contacto" size="lg" variant="primary" class="shadow-glow">
            Solicitar Diagnóstico Gratuito
          </CTAButton>
          <CTAButton href="#roi" size="lg" variant="outline">
            Ver Calculadora de ROI
          </CTAButton>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="py-24 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20 mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
              <span class="text-[10px] font-bold tracking-widest uppercase text-red-500">Fuga de ROI Detectada</span>
            </div>
            <h2 class="text-fluid-h2 font-bold mb-8 leading-tight text-gradient-white">
              ¿Su equipo está atrapado en <span class="text-brand-indigo">tareas invisibles</span>?
            </h2>
            <div class="space-y-6">
              {[
                "Correos repetitivos que consumen horas críticas.",
                "Silos de información en manuales desactualizados.",
                "Falta de trazabilidad en la atención al cliente.",
                "Procesos manuales que frenan el escalamiento."
              ].map(item => (
                <div class="flex items-center gap-4 group">
                  <div class="flex-shrink-0 h-6 w-6 text-red-400 group-hover:scale-110 transition-transform">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  </div>
                  <p class="text-lg text-brand-slate group-hover:text-brand-white transition-colors">{item}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="bg-brand-navy/30 backdrop-blur-xl p-10 rounded-[40px] border border-white/5 relative group overflow-hidden h-[500px] flex flex-col justify-end">
             <div class="absolute inset-0 bg-gradient-to-br from-brand-indigo/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
             <!-- Blueprint lines in the card -->
             <div class="absolute top-0 left-0 w-full h-px bg-white/5 z-20"></div>
             <div class="absolute top-0 left-0 w-px h-full bg-white/5 z-20"></div>
             
             <!-- 3D Canvas Background -->
             <div class="absolute inset-0 z-0 opacity-80 mix-blend-screen transition-opacity duration-1000 group-hover:opacity-100">
               <DataChaosCanvas client:load />
             </div>

             <div class="relative z-10 bg-brand-obsidian/80 backdrop-blur-md p-6 rounded-3xl border border-white/10 shadow-2xl">
               <div class="text-6xl font-black text-brand-primary mb-2 tracking-tighter">80%</div>
               <p class="text-xl font-bold mb-2 text-brand-white">Del trabajo administrativo es automatizable.</p>
               <p class="text-brand-slate text-sm leading-relaxed">
                 Thinka no es solo software; es la <strong class="text-white">infraestructura administrada</strong> que recupera el tiempo de su talento humano.
               </p>
               <div class="mt-4 pt-4 border-t border-white/5 flex items-center justify-between text-[10px] font-mono text-brand-primary/40 uppercase tracking-widest">
                 <span>análisis: listo</span>
                 <span>impacto: confirmado</span>
               </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Visual Transition: Problem to Solution -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-24 relative">
      <div class="absolute left-1/2 top-0 -translate-x-1/2 w-px h-full bg-gradient-to-b from-brand-indigo/20 via-brand-primary/50 to-brand-primary/20"></div>
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="w-8 h-8 rounded-full bg-brand-obsidian border border-brand-primary/30 flex items-center justify-center animate-bounce shadow-glow">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 14l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Use Cases Bento Grid -->
    <section id="soluciones" class="py-24 relative overflow-hidden blueprint-grid">
      <!-- Decorative Coordinates -->
      <div class="absolute top-8 left-8 text-[10px] font-mono text-white/20 tracking-widest uppercase pointer-events-none">
        lat: -29.9533 / lon: -71.3395
      </div>
      <div class="absolute bottom-8 right-8 text-[10px] font-mono text-white/20 tracking-widest uppercase pointer-events-none">
        status: system_active_0x4F
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-primary animate-pulse"></span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-brand-primary">Potencial de Crecimiento</span>
          </div>
          <h2 class="text-fluid-h2 font-bold mb-6 text-gradient-white">Casos de Uso de Alto Impacto</h2>
          <p class="text-brand-slate text-lg max-w-2xl mx-auto">
            Infraestructura de IA diseñada para resolver desafíos industriales con precisión quirúrgica.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {useCases.map((useCase, index) => (
            <SpotlightCard 
              class={`${useCase.span} reveal group`} 
              delay={index * 100}
            >
              <div class="flex flex-col h-full relative z-10">
                <div class="flex justify-between items-start mb-6">
                  <div class="inline-flex p-3 rounded-2xl bg-white/5 border border-white/10 text-brand-primary w-fit group-hover:scale-110 transition-transform duration-500">
                    <Fragment set:html={useCase.icon} />
                  </div>
                  
                  <!-- HD 3D Icon -->
                  <div class="w-32 h-32 -mt-10 -mr-10 pointer-events-none opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700">
                    <img 
                      src={`/assets/images/use-cases/${useCase.type}.png`} 
                      alt={useCase.title} 
                      class="ai-3d-icon w-full h-full object-contain opacity-0 transition-all duration-700"
                      loading="lazy"
                    />
                  </div>
                </div>
                
                <h3 class="text-2xl font-bold mb-4 text-brand-white group-hover:text-brand-primary transition-colors duration-300">
                  {useCase.title}
                </h3>
                <p class="text-brand-slate leading-relaxed mb-6">
                  {useCase.description}
                </p>
                <div class="mt-auto flex items-center gap-2 text-xs font-mono text-brand-primary/50 group-hover:text-brand-primary transition-colors">
                  <span class="w-8 h-[1px] bg-current"></span>
                  VER_ESTRATEGIA_0{index + 1}
                </div>
              </div>
            </SpotlightCard>
          ))}
        </div>
      </div>
    </section>

    <!-- Managed Process Section -->
    <section class="py-24 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-indigo/10 border border-brand-indigo/20 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-indigo animate-pulse"></span>
            <span class="text-[10px] font-bold tracking-widest uppercase text-brand-indigo">Metodología de Escalamiento</span>
          </div>
          <h2 class="text-fluid-h2 font-bold mb-6 text-gradient-white">Su IA lista en 3 pasos</h2>
          <p class="text-brand-slate text-lg">Infraestructura administrada. Nosotros ejecutamos, usted escala.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 relative max-w-6xl mx-auto pt-12">
          <!-- Desktop Connection Line -->
          <div class="hidden md:block absolute top-[4.5rem] left-[15%] right-[15%] h-[1px] bg-brand-primary/20 -z-10">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-primary/50 to-transparent animate-pulse"></div>
          </div>
          
          {[
            {
              step: "01",
              title: "Diagnóstico Estratégico",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8a3 3 0 0 0-3 3"/></svg>`,
              desc: "Analizamos su operación para identificar los puntos críticos de ineficiencia.",
              features: ["Auditoría de Procesos", "Mapa de Oportunidades", "Proyección de ROI"]
            },
            {
              step: "02",
              title: "Despliegue Managed",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="m20 7-8-4-8 4 8 4 8-4Z"/><path d="m20 12-8-4-8 4 8 4 8-4Z"/><path d="m20 17-8-4-8 4 8 4 8-4Z"/></svg>`,
              desc: "Construimos e integramos su infraestructura de IA de punta a punta.",
              features: ["Entrenamiento de Datos", "Configuración de Agentes", "Integración Segura"]
            },
            {
              step: "03",
              title: "Escalamiento & Mejora",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 20v-6M6 20V10M18 20V4"/></svg>`,
              desc: "Garantizamos que su IA aprenda y evolucione con su negocio mes a mes.",
              features: ["Re-entrenamiento Mensual", "Auditoría de Calidad", "Soporte Proactivo"]
            }
          ].map((item, index) => (
            <div class="relative group reveal" style={`animation-delay: ${index * 200}ms;`}>
              <!-- Step Indicator -->
              <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 rounded-full bg-brand-obsidian border border-brand-primary/30 flex items-center justify-center text-brand-primary mb-6 relative z-10 group-hover:scale-110 group-hover:border-brand-primary transition-all duration-500 shadow-[0_0_15px_rgba(0,255,148,0.1)] group-hover:shadow-[0_0_25px_rgba(0,255,148,0.3)]">
                  <div class="absolute inset-0 rounded-full bg-brand-primary/5 animate-ping opacity-20"></div>
                  <Fragment set:html={item.icon} />
                </div>
                
                <!-- Card -->
                <div class="w-full pt-8 pb-8 px-6 rounded-[32px] bg-brand-navy/30 border border-white/5 group-hover:border-brand-primary/20 transition-all duration-500 relative overflow-hidden h-full flex flex-col">
                  <!-- Subtle numbering background -->
                  <div class="absolute -top-4 -right-2 text-8xl font-black text-white/[0.03] pointer-events-none group-hover:text-brand-primary/[0.05] transition-colors duration-500 select-none">
                    {item.step}
                  </div>
                  
                  <h3 class="text-xl font-bold mb-3 text-brand-white relative z-10">{item.title}</h3>
                  <p class="text-brand-slate text-sm mb-6 leading-relaxed relative z-10">{item.desc}</p>
                  
                  <div class="mt-auto pt-6 border-t border-white/5 flex flex-col gap-2 relative z-10">
                    {item.features.map(feature => (
                      <div class="flex items-center gap-2 text-[12px] text-brand-slate/80 group-hover:text-brand-primary/90 transition-colors">
                        <div class="w-1 h-1 rounded-full bg-brand-primary/40 group-hover:bg-brand-primary transition-colors"></div>
                        {feature}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ROI Section -->
    <section id="roi" class="py-24 relative overflow-hidden blueprint-grid">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="mb-16 text-center">
           <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 mb-4">
             <span class="w-1.5 h-1.5 rounded-full bg-brand-primary animate-pulse"></span>
             <span class="text-[10px] font-bold tracking-widest uppercase text-brand-primary">Métricas de Retorno (ROI)</span>
           </div>
           <h2 class="text-fluid-h2 font-bold mb-6 text-gradient-white">Resultados Medibles, No Promesas</h2>
           <p class="text-brand-slate text-lg">La IA es una inversión en eficiencia. Calcule su impacto real aquí.</p>
        </div>
        <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-8 items-center">
          <div class="bg-brand-navy/50 backdrop-blur-xl border border-white/10 rounded-[40px] p-4 md:p-8 shadow-2xl">
            <ROICalculator />
          </div>
          
          <div class="hidden lg:flex relative h-full min-h-[500px] rounded-[40px] border border-white/5 bg-gradient-to-t from-brand-navy/30 to-transparent items-center justify-center overflow-hidden">

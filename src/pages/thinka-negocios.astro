---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thinka Negocio - Tu Partner en Gestión de Negocios" description="Thinka Negocio - La solución completa para la gestión de negocios de servicios. Ventas, inventario, personal y contabilidad en una sola plataforma.">
  <style>
    /* Estilos específicos para esta landing */
    .hero-visual .code-window {
        max-width: 500px;
    }

    .check-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0;
    }

    .check-list li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
        color: var(--text-secondary);
    }

    .check-list li svg {
        color: var(--primary);
        flex-shrink: 0;
    }

    .faq-item {
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1.5rem;
    }

    .faq-question {
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .faq-answer {
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .module-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .module-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
    }
  </style>

  <Header>
    <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="#dashboard" class="nav-link">Dashboard</a></li>
        <li><a href="#modulos" class="nav-link">Módulos</a></li>
        <li><a href="#seguridad" class="nav-link">Seguridad</a></li>
        <li><a href="#faq" class="nav-link">FAQ</a></li>
        <li><a href="#contacto" class="nav-link">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
     <!-- Hero Section -->
     <section id="home" class="hero" aria-labelledby="hero-title">
        <div class="hero-background">
            <div class="hero-gradient"></div>
            <div class="hero-pattern"></div>
        </div>
        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                    </svg>
                    <span>Gestión Integral</span>
                </div>
                <h1 id="hero-title" class="hero-title">
                    <span class="hero-title-main">Thinka Negocio</span>
                    <span class="hero-title-highlight">Tu Partner en Gestión</span>
                    <span class="hero-title-sub">Solución completa para negocios de servicios</span>
                </h1>
                <p class="hero-description">
                    Gestiona ventas, productos, servicios, sucursales y personal en una sola plataforma.
                    Toma el control total de tu negocio con herramientas avanzadas de administración y reportes
                    financieros.
                </p>
                <div class="hero-actions">
                    <a href="#contacto" class="btn btn-primary btn-hero">
                        <span>Solicitar Demo</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </a>
                    <a href="#modulos" class="btn btn-secondary btn-hero">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                        </svg>
                        <span>Ver Módulos</span>
                    </a>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-animation">
                    <!-- Representación simplificada del Dashboard -->
                    <div class="code-window">
                        <div class="window-header">
                            <div class="window-controls">
                                <span class="control red"></span>
                                <span class="control yellow"></span>
                                <span class="control green"></span>
                            </div>
                            <div class="window-title">Dashboard Thinka Negocio</div>
                        </div>
                        <div class="code-content" style="padding: 20px; font-family: 'Inter', sans-serif;">
                            <div
                                style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px;">
                                <div style="background: rgba(255,255,255,0.1); padding: 10px; border-radius: 8px;">
                                    <div style="font-size: 0.8rem; color: #888;">Ventas del día</div>
                                    <div style="font-size: 1.2rem; font-weight: bold; color: var(--primary);">$
                                        1.250.000</div>
                                </div>
                                <div style="background: rgba(255,255,255,0.1); padding: 10px; border-radius: 8px;">
                                    <div style="font-size: 0.8rem; color: #888;">Clientes</div>
                                    <div style="font-size: 1.2rem; font-weight: bold; color: var(--secondary);">24
                                    </div>
                                </div>
                            </div>
                            <div
                                style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; margin-bottom: 10px;">
                                <div style="font-size: 0.9rem; margin-bottom: 5px;">Últimas Ventas</div>
                                <div
                                    style="font-size: 0.8rem; display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.1); padding: 5px 0;">
                                    <span>Servicio Computación</span>
                                    <span style="color: #4cd964;">$ 45.000</span>
                                </div>
                                <div
                                    style="font-size: 0.8rem; display: flex; justify-content: space-between; padding: 5px 0;">
                                    <span>Mantenimiento Preventivo</span>
                                    <span style="color: #4cd964;">$ 80.000</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Dashboard Section -->
    <section id="dashboard" class="services" aria-labelledby="dashboard-title">
        <div class="container">
            <div class="section-header">
                <div class="section-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="3" y1="9" x2="21" y2="9"></line>
                        <line x1="9" y1="21" x2="9" y2="9"></line>
                    </svg>
                    <span>Visión General</span>
                </div>
                <h2 id="dashboard-title" class="section-title">Panel Principal Intuitivo</h2>
                <p class="section-description">
                    Todo lo que necesitas saber sobre tu negocio en un solo vistazo.
                </p>
            </div>

            <div class="services-grid">
                <div class="service-card module-card" data-aos="fade-up">
                    <div class="service-header">
                        <div class="service-icon"
                            style="background: linear-gradient(135deg, #FF6B6B 0%, #EE5253 100%);">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path>
                                <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path>
                                <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Resumen en Tiempo Real</h3>
                    <p class="service-description">Visualiza tarjetas de resumen con ventas del día, clientes
                        atendidos y productos vendidos al instante.</p>
                </div>

                <div class="service-card module-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="service-header">
                        <div class="service-icon"
                            style="background: linear-gradient(135deg, #4834d4 0%, #686de0 100%);">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <line x1="18" y1="20" x2="18" y2="10"></line>
                                <line x1="12" y1="20" x2="12" y2="4"></line>
                                <line x1="6" y1="20" x2="6" y2="14"></line>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Indicadores de Rendimiento</h3>
                    <p class="service-description">Gráficos detallados y ranking de productos/servicios más vendidos
                        para tomar mejores decisiones.</p>
                </div>

                <div class="service-card module-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="service-header">
                        <div class="service-icon"
                            style="background: linear-gradient(135deg, #20bf6b 0%, #2ecc71 100%);">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Transacciones Recientes</h3>
                    <p class="service-description">Acceso rápido a las últimas ventas y movimientos realizados en tu
                        negocio.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Sales & Products Section -->
    <section id="modulos" class="services" aria-labelledby="modulos-title"
        style="background-color: var(--bg-secondary);">
        <div class="container">
            <div class="section-header">
                <div class="section-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                    </svg>
                    <span>Potencia tu Operación</span>
                </div>
                <h2 id="modulos-title" class="section-title">Módulos Principales</h2>
                <p class="section-description">
                    Herramientas diseñadas para cubrir cada aspecto de tu operación diaria.
                </p>
            </div>

            <div class="services-grid">
                <!-- Ventas -->
                <div class="service-card featured-service" data-aos="fade-up">
                    <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                                <line x1="3" y1="6" x2="21" y2="6"></line>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                        </div>
                        <div class="service-badge">Core</div>
                    </div>
                    <h3 class="service-title">Gestión de Ventas</h3>
                    <p class="service-description">
                        Registra ventas de productos y servicios de forma ágil y rápida.
                    </p>
                    <ul class="check-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Cálculo automático de IVA y Comisiones
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Generación de comprobantes PDF
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Control de Stock automático
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Anulación y gestión de historial
                        </li>
                    </ul>
                </div>

                <!-- Productos y Servicios -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path
                                    d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z">
                                </path>
                                <line x1="7" y1="7" x2="7.01" y2="7"></line>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Productos y Servicios</h3>
                    <p class="service-description">
                        Catalogación completa de tu inventario y oferta de servicios.
                    </p>
                    <ul class="check-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Gestión de códigos y categorías
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Alertas de stock mínimo
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Kardex de movimientos
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Asociación de insumos a servicios
                        </li>
                    </ul>
                </div>

                <!-- Personal y Sucursales -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Equipo y Sucursales</h3>
                    <p class="service-description">
                        Administra tu personal y múltiples ubicaciones eficientemente.
                    </p>
                    <ul class="check-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Gestión multi-sucursal
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Registro detallado de trabajadores
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Cálculo automático de comisiones
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Roles y permisos de usuario
                        </li>
                    </ul>
                </div>

                <!-- Contabilidad -->
                <div class="service-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Contabilidad</h3>
                    <p class="service-description">
                        Mantén tus números claros y ordenados.
                    </p>
                    <ul class="check-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Resumen financiero (Ingresos/Egresos)
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Reportes exportables (Excel/PDF)
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Estado de resultados
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                            Control de IVA
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <!-- Seguridad y Movil Section -->
    <section id="seguridad" class="about" aria-labelledby="seguridad-title">
        <div class="container">
            <div class="about-content">
                <div class="about-text" data-aos="fade-right">
                    <h2 id="seguridad-title" class="section-title">Seguridad y Acceso en Todo Lugar</h2>
                    <p class="about-description">
                        Thinka Negocio está diseñado pensando en la seguridad de tus datos y la flexibilidad de tu
                        operación.
                    </p>

                    <div class="tech-stack">
                        <h3 class="tech-title">Características Clave</h3>
                        <ul class="check-list" style="margin-top: 1rem;">
                            <li>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                                <strong>Seguridad:</strong> Encriptación SSL/TLS, auditoría completa y backups
                                automáticos.
                            </li>
                            <li>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                                    <line x1="12" y1="18" x2="12.01" y2="18"></line>
                                </svg>
                                <strong>Full Responsive:</strong> Accede desde tu móvil, tablet o computador.
                                Interfaz optimizada para touch.
                            </li>
                            <li>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                                </svg>
                                <strong>Roles y Permisos:</strong> Control granular de lo que cada usuario puede ver
                                y hacer.
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="about-visual" data-aos="fade-left">
                    <!-- Placeholder para imagen de seguridad o movil -->
                    <div class="hero-animation"
                        style="height: 300px; display: flex; align-items: center; justify-content: center;">
                        <div style="text-align: center;">
                            <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="1" style="color: var(--primary);">
                                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                                <line x1="12" y1="18" x2="12.01" y2="18"></line>
                            </svg>
                            <div style="margin-top: 1rem; font-weight: bold; font-size: 1.2rem;">Lleva tu negocio
                                contigo</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="services" aria-labelledby="faq-title" style="background-color: var(--bg-secondary);">
        <div class="container">
            <div class="section-header">
                <h2 id="faq-title" class="section-title">Preguntas Frecuentes</h2>
                <p class="section-description">Resolvemos tus dudas sobre Thinka Negocio</p>
            </div>

            <div class="services-grid" style="grid-template-columns: 1fr; max-width: 800px; margin: 0 auto;">
                <div class="faq-item">
                    <div class="faq-question">¿Puedo trabajar offline?</div>
                    <div class="faq-answer">No, Thinka Negocio es una solución basada en la nube y requiere conexión
                        a internet estable para garantizar que tus datos estén siempre sincronizados y seguros.
                    </div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Es compatible con mi navegador?</div>
                    <div class="faq-answer">Sí, es compatible con los principales navegadores modernos: Google
                        Chrome (recomendado), Mozilla Firefox, Microsoft Edge y Safari.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Mis datos están seguros?</div>
                    <div class="faq-answer">Absolutamente. Utilizamos encriptación SSL/TLS de nivel bancario,
                        contraseñas encriptadas y realizamos backups automáticos periódicamente.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Cómo recupero mi contraseña?</div>
                    <div class="faq-answer">En la pantalla de inicio de sesión, haz clic en "¿Olvidaste tu
                        contraseña?". Recibirás un correo con las instrucciones para restablecerla de forma segura.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Support Section -->
    <section id="soporte" class="testimonials" aria-labelledby="soporte-title">
        <div class="container">
            <div class="section-header">
                <h2 id="soporte-title" class="section-title">¿Necesitas Ayuda?</h2>
                <p class="section-description">Nuestro equipo de soporte está listo para asistirte.</p>
            </div>

            <div class="services-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                <div class="service-card" style="text-align: center;">
                    <div style="margin-bottom: 1rem; color: var(--primary);">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z">
                            </path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </div>
                    <h3>Email</h3>
                    <p>soporte@thinka.cl</p>

                <!-- Discount Steps (New Design) -->
                <div class="discount-steps">
                    <!-- Step 1 -->
                    <div class="discount-step" data-aos="fade-up">
                        <div class="discount-circle">
                            <div>
                                <div class="discount-value">10%</div>
                                <div class="discount-label">Desc.</div>
                            </div>

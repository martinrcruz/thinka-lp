                    <!-- Step 2 -->
                    <div class="discount-step" data-aos="fade-up" data-aos-delay="100">
                        <div class="discount-circle">
                            <div>
                                <div class="discount-value">20%</div>
                                <div class="discount-label">Desc.</div>
                            </div>
                        </div>
                        <h4 class="step-title">4 – 6 Asistentes</h4>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style>
    /* Override Global Colors for this page only */
    :root {
        --primary-color: #119DF3 !important;
        --primary-dark: #0077c2 !important;
        --primary-light: #6ac4ff !important;
        --secondary-color: #3A405A !important;
        --white: #FFFFFF !important;
        
        /* Adjusting gradient colors to match new primary/secondary */
        --gradient-start: var(--primary-color);
        --gradient-end: var(--secondary-color);
    }

    /* Hide Language and Theme Toggles */
    :global(.language-toggle),
    :global(.theme-toggle) {
        display: none !important;
    }

    /* Icon overrides: Default state = Primary Color */
    .service-icon {
        color: var(--primary-color) !important;
    }

    /* For the featured card (dark background), set icon bg to white so the primary-colored icon is visible */
    .featured-service .service-icon {
        background: var(--white) !important;
        color: var(--primary-color) !important;
    }

    /* Hover state: White Icon (as requested) */
    .service-card:hover .service-icon {
        color: var(--white) !important;
        background: var(--primary-color) !important;
    }

    /* Featured card hover: Keep white icon, use transparent white bg */
    .featured-service:hover .service-icon {
        color: var(--white) !important;
        background: rgba(255, 255, 255, 0.2) !important;
    }

    /* Custom styles for new sections */
    /* Removed old table styles */

    .info-box {
        background: var(--gray-50);
        padding: 1rem 1.5rem;
        border-radius: var(--radius-md);
        margin: 1.5rem auto; /* Center horizontally */
        max-width: 800px;
        text-align: center; /* Center text */
    }
    
    .feature-list {
        list-style: none;
        padding: 0;
    }
    
    .feature-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .feature-list li svg {
        flex-shrink: 0;
        color: var(--primary-color);
    }

    /* Custom stat class to avoid conflict with global animations.js */
    .stat-value-custom {
        font-family: 'Inter', sans-serif;
        line-height: 1;
    }

    /* Value Props Grid */
    .value-props-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        margin-top: 4rem;
    }

    @media (min-width: 768px) {
        .value-props-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .value-prop-card {
        background: var(--white);
        padding: 2rem;
        border-radius: 1rem;
        border: 1px solid var(--gray-200);
        transition: all 0.3s ease;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .value-prop-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
        border-color: var(--primary-color);
    }

    .prop-icon {
        background: rgba(17, 157, 243, 0.1);
        color: var(--primary-color);
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.3s ease;
    }

    .value-prop-card:hover .prop-icon {
        background: var(--primary-color);
        color: var(--white);
    }

    .prop-content h4 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--gray-900);
    }

    .prop-content p {
        font-size: 0.95rem;
        color: var(--gray-600);
        line-height: 1.5;
    }
    .discount-steps {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
        margin-top: 3rem;
        position: relative;
    }

    .discount-step {
        position: relative;
        text-align: center;
        flex: 1;
        min-width: 200px;
        max-width: 280px;
        z-index: 1;
    }

    /* Connector Line */
    .discount-steps::before {
        content: '';
        position: absolute;
        top: 50px; /* Adjust based on circle size */
        left: 15%;
        width: 70%;
        height: 4px;
        background: var(--gray-200);
        z-index: 0;
        transform: translateY(-50%);
    }

    @media (max-width: 768px) {
        .discount-steps::before {
            display: none; /* Hide line on mobile */
        }
        .discount-steps {
            flex-direction: column;
            gap: 3rem;
        }
    }

    .discount-circle {
        width: 100px;
        height: 100px;
        background: var(--white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem auto;
        position: relative;
        box-shadow: var(--shadow-lg);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 4px solid var(--white);
    }
    
    .discount-circle::after {
        content: '';
        position: absolute;
        top: -4px;
        left: -4px;
        right: -4px;
        bottom: -4px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        z-index: -1;
    }

    .discount-step:hover .discount-circle {
        transform: scale(1.15) rotate(5deg);
        box-shadow: 0 15px 30px rgba(17, 157, 243, 0.3);
        background: var(--primary-color);
        border-color: var(--primary-color);
    }

    .discount-step:hover .discount-value,
    .discount-step:hover .discount-label {
        color: var(--white);
    }

    .discount-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary-color);
        line-height: 1;
    }

    .discount-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-500);
        margin-top: 0.25rem;
        font-weight: 600;
    }

    .step-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 0.5rem;
    }

    .step-desc {
        color: var(--gray-600);
        font-size: 0.95rem;
    }
    .pricing-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        margin-top: 3rem;
    }
    
    @media (min-width: 768px) {
        .pricing-grid {
             grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        }
    }

    .pricing-card {
        background: var(--white);
        border: 1px solid var(--gray-200); /* Visible border */
        border-radius: 1.5rem;
        padding: 2.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        height: 100%;
        justify-content: space-between;
    }
    
    .pricing-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.1);
        border-color: var(--primary-color);
    }

    .card-header {
        margin-bottom: 2rem;
        width: 100%;
    }

    .plan-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.75rem;
    }

    .plan-credits {
        font-size: 0.95rem;
        color: var(--secondary-color);
        font-weight: 600;
        background: rgba(58, 64, 90, 0.1); /* Secondary color faint bg */
        padding: 0.35rem 0.85rem;
        border-radius: 2rem;
        display: inline-block;
    }

    .card-price {
        margin-bottom: 1.5rem;
        color: var(--gray-900);
        display: flex;
        justify-content: center;
        align-items: flex-start;
        line-height: 1;
    }

    .card-price .currency {
        font-size: 1.25rem;
        font-weight: 600;
        margin-top: 0.25rem;
        margin-right: 0.25rem;
        color: var(--gray-600);
    }

    .card-price .amount {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .card-meta {
        margin-bottom: 2rem;
        color: var(--gray-500);
        font-size: 0.9rem;
        font-weight: 500;
        min-height: 1.5em;
    }

    .pricing-card .feature-list {
        margin: 0 0 2rem 0;
        width: 100%;
        text-align: left;
    }
    
    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
        color: var(--gray-700);
    }
    
    .check-icon {
        width: 1.25rem;
        height: 1.25rem;
        color: var(--primary-color); /* Green tick or primary color? Using primary for brand consistency */
        flex-shrink: 0;
    }

    .card-action {
        width: 100%;
        margin-top: auto;
    }

    .btn-plan {
        display: block;
        width: 100%;
        padding: 0.875rem 1rem;
        background-color: var(--primary-color);
        border: 2px solid var(--primary-color);
        color: #ffffff;
        text-decoration: none;
        font-weight: 600;
        border-radius: 0.75rem;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 0.95rem;
        cursor: pointer;
    }
    
    .btn-plan:hover {
        background-color: var(--primary-dark);
        border-color: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(17, 157, 243, 0.3);
    }

    /* Popular Card Styling */
    .popular-card {
        border: 2px solid var(--secondary-color);
        transform: scale(1.05); 
        z-index: 2;
        box-shadow: 0 12px 24px rgba(58, 64, 90, 0.12);
    }
    
    .popular-card:hover {
        transform: scale(1.05) translateY(-8px);
        box-shadow: 0 20px 40px rgba(58, 64, 90, 0.2);
    }

    .popular-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--secondary-color);
        color: white;
        text-transform: uppercase;
        font-size: 0.8rem;
        font-weight: 700;
        padding: 0.25rem 1rem;
        border-radius: 1rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    
    .btn-popular {
        background-color: var(--secondary-color);
        border-color: var(--secondary-color);
    }
    
    .btn-popular:hover {
        background-color: #2c3144; /* Darker secondary */
        border-color: #2c3144;
    }

        padding: 1.5rem;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        margin: 1.5rem 0;
    }
    
    .feature-list {
        list-style: none;
        padding: 0;
    }
    
    .feature-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .feature-list li svg {
        flex-shrink: 0;
        color: var(--primary-color);
    }
/* Custom stat class to avoid conflict with global animations.js */
    .stat-value-custom {
        font-family: 'Inter', sans-serif;
        line-height: 1;
    }
</style>

<Layout title="Thinka Asistente | Chatbots de IA Avanzada" description="Asistentes virtuales inteligentes con procesamiento de lenguaje natural. Automatiza el soporte y las ventas 24/7 con Thinka Asistente." favicon="/assets/logo/fav-asistente.png">
  <Header logoSrc="/assets/images/asistente-claro.png">
    <ul class="nav-list">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="#about" class="nav-link">¿Qué es?</a></li>
        <li><a href="#features" class="nav-link">Capacidades</a></li>
        <li><a href="#integrations" class="nav-link">Canales</a></li>
        <li><a href="#pricing" class="nav-link">Planes</a></li>
        <li><a href="#contact" class="nav-link">Contacto</a></li>
    </ul>
  </Header>

  <main id="main-content" role="main">
    <!-- Hero Section -->
    <section id="home" class="hero" aria-labelledby="hero-title">
        <div class="hero-background">
            <div class="hero-gradient"></div>
            <div class="hero-pattern"></div>
        </div>
        <div class="hero-container">
            <div class="hero-content">
                <div class="hero-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span>IA Conversacional</span>
                </div>
                <h1 id="hero-title" class="hero-title">
                    <span class="hero-title-main">Thinka Asistente</span>
                    <span class="hero-title-highlight">Tu Agente 24/7</span>
                    <span class="hero-title-sub">Atención al Cliente Inteligente</span>
                </h1>
                <p class="hero-description">
                    Revoluciona la comunicación con tus clientes. Nuestros chatbots entienden el contexto, aprenden de cada interacción y resuelven consultas complejas al instante, liberando a tu equipo para tareas estratégicas.
                </p>
                <div class="hero-actions">
                    <a href="#pricing" class="btn btn-primary btn-hero">
                        <span>Ver Planes</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </a>
                    <a href="#contact" class="btn btn-secondary btn-hero">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                             <circle cx="12" cy="12" r="10"></circle>
                             <polygon points="10 8 16 12 10 16 10 8"></polygon>
                        </svg>
                        <span>Solicitar Demo</span>
                    </a>
                </div>
            </div>
            <!-- Hero Visual (Kept as is) -->
            <div class="hero-visual">
                <div class="hero-animation">
                     <div class="code-window">
                        <div class="window-header">
                            <div class="window-controls">
                                <span class="control red"></span>
                                <span class="control yellow"></span>
                                <span class="control green"></span>
                            </div>
                            <div class="window-title">Chat.tsx</div>
                        </div>
                        <div class="code-content">
                            <div class="code-line">
                                <span class="line-number">1</span>
                                <span class="code-text"><span class="comment">// User: "Quiero agendar una hora"</span></span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">2</span>
                                <span class="code-text"><span class="keyword">const</span> intent = <span class="class">NLP</span>.detect(input);</span>
                            </div>
                            <div class="code-line">
                                <span class="line-number">3</span>
                                <span class="code-text"><span class="keyword">if</span> (intent === <span class="string">'BOOKING'</span>) {</span>
                            </div>
                             <div class="code-line">
                                <span class="line-number">4</span>
                                <span class="code-text">  <span class="keyword">return</span> <span class="class">Calendar</span>.getSlots();</span>
                            </div>
                             <div class="code-line typing">
                                <span class="line-number">5</span>
                                <span class="code-text">}</span>
                            </div>
                        </div>
                    </div>
                     <div class="floating-elements">
                        <div class="floating-card ai-card">
                            <div class="card-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"></path>
                                    <path d="M12 16v-4"></path>
                                    <path d="M8 12h8"></path>
                                </svg>
                            </div>
                            <div class="card-title">NLP Avanzado</div>
                            <div class="card-metric">Entiende Contexto</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- NEW SECTION: What is Thinka Asistente -->
    <section id="about" class="about-section" style="padding: 5rem 0; background-color: var(--white);">
        <div class="container">
            <div class="section-header" style="text-align: center; max-width: 800px; margin: 0 auto;">
                <div class="section-badge">
                   <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                     <circle cx="12" cy="12" r="10"></circle>
                     <line x1="12" y1="16" x2="12" y2="12"></line>
                     <line x1="12" y1="8" x2="12.01" y2="8"></line>
                   </svg>
                    <span>Sobre la Plataforma</span>
                </div>
                <h2 class="section-title">¿Qué es Thinka Asistente?</h2>
                <div class="section-description" style="font-size: 1.125rem; color: var(--gray-700);">
                    <p>
                        <strong>Thinka Asistente</strong> es una plataforma de <strong>asistentes virtuales inteligentes</strong>, desarrollada sobre <strong>Spring Boot y Spring AI</strong>, completamente configurable según los objetivos del negocio.
                    </p>
                    <p style="margin-top: 1rem;">
                        No es un chatbot genérico, sino un <strong>asistente entrenado y delimitado</strong> para tareas específicas.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section (Existing) -->
    <section id="features" class="services" aria-labelledby="features-title" style="background-color: var(--gray-50);">
        <div class="container">
            <div class="section-header">
                <div class="section-badge">
                   <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                     <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                   </svg>
                    <span>Características</span>
                </div>
                <h2 id="features-title" class="section-title">Más que un Chatbot</h2>
                <p class="section-description">
                    Potenciado por modelos de lenguaje de última generación (LLMs) para ofrecer experiencias conversacionales humanas.
                </p>
            </div>

            <div class="services-grid">
                <!-- Original Keep Cards -->
                <div class="service-card featured-service" data-aos="fade-up">
                    <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                            </svg>
                        </div>
                        <div class="service-badge">Core</div>
                    </div>
                    <h3 class="service-title">Procesamiento de Lenguaje Natural</h3>
                    <p class="service-description">
                        No funciona con keywords rígidas. Entiende la intención, el sentimiento y el contexto de cada mensaje.
                    </p>
                    <ul class="service-features">
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Análisis de Sentimiento</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Manejo de Contexto</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Corrección Automática</li>
                    </ul>
                </div>
                <div class="service-card" data-aos="fade-up" data-aos-delay="100">
                     <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Omnicanalidad</h3>
                    <p class="service-description">
                        Despliega tu asistente donde tus clientes están. Una sola configuración, múltiples canales.
                    </p>
                     <ul class="service-features">
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> WhatsApp Business API</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Instagram DM</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Widget Web</li>
                    </ul>
                </div>
                <div class="service-card" data-aos="fade-up" data-aos-delay="200">
                     <div class="service-header">
                        <div class="service-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                    </div>
                    <h3 class="service-title">Agendamiento Automático</h3>
                    <p class="service-description">
                        Permite que tus clientes agenden reuniones o servicios directamente en el chat, sincronizado con tu calendario.
                    </p>
                    <ul class="service-features">
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Google Calendar / Outlook</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Recordatorios</li>
                        <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Gestión de Cupos</li>
                    </ul>
                </div>
            </div>
            
            <!-- NEW SSECTION: Detailed List of Capabilities -->
            <!-- NEW SECTION: Detailed List of Capabilities (Redesigned) -->
            <div style="margin-top: 5rem;" data-aos="fade-up">
                <h3 class="section-title" style="font-size: 1.75rem; margin-bottom: 3rem; text-align: center;">Capacidades Principales</h3>
                 <!-- Changed to Flexbox for centering logic: 3 top, 2 bottom centered -->
                 <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem;">
                    <!-- Card 1 -->

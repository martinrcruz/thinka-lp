---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SimpleFooter from '../components/SimpleFooter.astro';
import Icon from '../components/Icon.astro';

const values = [
  {
    title: "Excelencia Técnica",
    description: "Nos apasiona el código bien escrito y las arquitecturas que escalan.",
    icon: "code"
  },
  {
    title: "Innovación con IA",
    description: "No solo seguimos tendencias, las implementamos para generar valor real.",
    icon: "cpu"
  },
  {
    title: "Compromiso",
    description: "Tu éxito es el nuestro. Trabajamos como socios estratégicos.",
    icon: "shield"
  }
];
---

<Layout 
  title="Nosotros | Thinka"
  description="Conoce al equipo detrás de Thinka y nuestra misión de transformar empresas a través de Software e Inteligencia Artificial."
>
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="relative py-20 lg:py-32 overflow-hidden bg-white dark:bg-gray-900">
      <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12 relative z-10">
        <div class="max-w-3xl">
          <h1 class="text-5xl lg:text-7xl font-black text-gray-900 dark:text-white mb-8 leading-tight tracking-tight">
            Impulsando el futuro <br/>
            <span class="bg-gradient-to-r from-purple-600 to-indigo-600 bg-clip-text text-transparent italic pr-4 py-2" style="box-decoration-break: clone; -webkit-box-decoration-break: clone;">del Software e IA</span>
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed font-medium">
            En Thinka, combinamos ingeniería de software de clase mundial con la potencia de la Inteligencia Artificial para resolver los desafíos más complejos de la industria moderna.
          </p>
        </div>
      </div>
    </section>

    <!-- Nuestra Misión -->
    <section class="py-20 bg-gray-50 dark:bg-gray-950/20">
      <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-12">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl lg:text-4xl font-black text-gray-900 dark:text-white mb-6">Nuestra Misión</h2>
            <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
              Nacimos con el objetivo de democratizar el acceso a tecnologías de vanguardia. Ayudamos a empresas de todos los tamaños a automatizar procesos, optimizar su operación y escalar sus productos digitales sin fricciones.
            </p>
            <div class="grid gap-6">
              {values.map(value => (
                <div class="flex items-start p-6 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm">
                  <div class="w-12 h-12 rounded-xl bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-6 shrink-0">
                    <Icon name={value.icon as any} size={24} />
                  </div>
                  <div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{value.title}</h3>
                    <p class="text-gray-600 dark:text-gray-400">{value.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="relative">
            <div class="aspect-square rounded-[3rem] bg-gradient-to-br from-purple-600 to-indigo-700 p-1 overflow-hidden shadow-2xl">
              <div class="w-full h-full bg-gray-900 rounded-[2.8rem] flex items-center justify-center p-12 text-center">
                <div>
                  <div class="text-6xl font-black text-white mb-4">+10</div>
                  <p class="text-purple-200 font-bold uppercase tracking-widest text-sm">Años de experiencia combinada</p>
                </div>
              </div>
            </div>
            <!-- Decorative circle -->
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-purple-500/20 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SimpleFooter />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import SimpleFooter from '../../components/SimpleFooter.astro';
import Icon from '../../components/Icon.astro';

const devFeatures = [
  {
    title: "Backend Robusto",
    description: "Desarrollo de APIs rápidas, seguras y escalables con Node.js, Python, Go o Rust.",
    icon: "code"
  },
  {
    title: "Frontend de Alto Impacto",
    description: "Interfaces modernas con React, Vue o Astro, optimizadas para el rendimiento y SEO.",
    icon: "eye"
  },
  {
    title: "DevOps & Cloud",
    description: "Automatización de despliegues (CI/CD) y gestión de infraestructura en AWS, GCP o Azure.",
    icon: "package"
  },
  {
    title: "Mantenimiento Evolutivo",
    description: "Garantizamos que tu software crezca y se adapte a las nuevas necesidades del mercado.",
    icon: "activity"
  }
];
---

<Layout 
  title="Desarrollo de Software a Medida | Thinka"
  description="Expertos en desarrollo de software de alta calidad. Creamos aplicaciones web y móviles robustas, seguras y escalables para empresas modernas."
>
  <Navbar />
  
  <main class="bg-white dark:bg-gray-900">
    <!-- Hero Dev -->
    <section class="relative py-24 lg:py-32 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-gray-50 to-white dark:from-gray-900 dark:to-gray-800 pointer-events-none"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div>
            <nav class="flex mb-8" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-2">
                <li><a href="/" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">Inicio</a></li>
                <li><Icon name="arrow-right" size={12} class="text-gray-400" /></li>
                <li><span class="text-sm font-bold text-gray-900">Servicios</span></li>
              </ol>
            </nav>
            <h1 class="text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white leading-tight">
              Desarrollo de <span class="text-purple-600">Software</span> a Medida
            </h1>
            <p class="mt-8 text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
              En Thinka, la excelencia técnica es nuestra base. Desarrollamos software corporativo de alto impacto, enfocado en la seguridad, escalabilidad y una experiencia de usuario inigualable.
            </p>
            <div class="mt-12 flex flex-col sm:flex-row gap-4">
              <a href="/cotizar" class="inline-flex justify-center items-center px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-2xl hover:bg-gray-800 dark:hover:bg-gray-100 transition-all shadow-lg">
                Iniciar Proyecto
              </a>
              <a href="#especialidades" class="inline-flex justify-center items-center px-8 py-4 border-2 border-gray-100 dark:border-gray-800 text-gray-600 dark:text-gray-300 font-bold rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
                Nuestras Especialidades
              </a>
            </div>
          </div>
          <div class="mt-16 lg:mt-0 relative">
             <div class="relative bg-gray-900 rounded-3xl overflow-hidden shadow-2xl p-8 border border-gray-800">
               <div class="flex items-center gap-2 mb-8">
                 <div class="w-3 h-3 rounded-full bg-red-500"></div>
                 <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                 <div class="w-3 h-3 rounded-full bg-green-500"></div>
               </div>
               <div class="space-y-4 font-mono text-sm">
                 <p class="text-purple-400"><span class="text-indigo-400">class</span> ThinkaSoftware <span class="text-white">{</span></p>
                 <p class="pl-4 text-purple-400">  <span class="text-indigo-400">constructor</span>(requirements) <span class="text-white">{</span></p>
                 <p class="pl-8 text-indigo-300">    this.quality = <span class="text-yellow-300">'Senior'</span>;</p>
                 <p class="pl-8 text-indigo-300">    this.architecture = <span class="text-yellow-300">'Scalable'</span>;</p>
                 <p class="pl-8 text-indigo-300">    this.security = <span class="text-yellow-300">'Hardened'</span>;</p>
                 <p class="pl-4 text-white">  }</p>
                 <p class="pl-4 text-purple-400">  <span class="text-indigo-400">async</span> build() <span class="text-white">{</span></p>
                 <p class="pl-8 text-indigo-300">    <span class="text-indigo-400">return await</span> this.deploy();</p>
                 <p class="pl-4 text-white">  }</p>
                 <p class="text-white">}</p>
               </div>
               <!-- Code editor decoration -->
               <div class="absolute bottom-4 right-4 text-gray-600 text-[10px] font-mono">UTF-8 | Typescript | Thinka Core</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Specialties Grid -->
    <section id="especialidades" class="py-24 bg-gray-50 dark:bg-gray-800/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white">Nuestro Stack de Desarrollo</h2>
          <p class="mt-4 text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Combinamos las mejores herramientas con una ejecución impecable para entregar resultados de clase mundial.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {devFeatures.map(f => (
            <div class="bg-white dark:bg-gray-900 p-8 rounded-3xl border border-gray-100 dark:border-gray-800 hover:shadow-xl transition-all duration-300 group">
              <div class="w-14 h-14 bg-gray-100 dark:bg-gray-800 rounded-2xl flex items-center justify-center text-gray-900 dark:text-white mb-6 group-hover:scale-110 transition-transform">
                <Icon name={f.icon as any} size={28} />
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">{f.title}</h3>
              <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial Section -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white dark:bg-gray-900 p-12 rounded-[3rem] shadow-2xl border border-gray-100 dark:border-gray-800 text-center relative overflow-hidden">
           <Icon name="package" size={100} class="absolute -top-10 -right-10 opacity-5 text-gray-400" />
           <p class="text-2xl lg:text-3xl font-medium text-gray-900 dark:text-white italic leading-relaxed">"La calidad del código y la arquitectura de Thinka superó nuestras expectativas. Han sido el socio tecnológico clave para nuestra expansión."</p>
           <div class="mt-12">
             <p class="text-lg font-bold text-gray-900 dark:text-white">Director de Ingeniería</p>
             <p class="text-purple-600">Enterprise Fintech Partner</p>
           </div>
        </div>
      </div>
    </section>
  </main>

  <SimpleFooter />
</Layout>

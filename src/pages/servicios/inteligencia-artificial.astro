---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import SimpleFooter from '../../components/SimpleFooter.astro';
import Icon from '../../components/Icon.astro';

const aiFeatures = [
  {
    title: "Modelos LLM Customizados",
    description: "Ajustamos modelos de lenguaje para que entiendan el contexto específico de tu industria y marca.",
    icon: "cpu"
  },
  {
    title: "Agentes Autónomos",
    description: "Sistemas capaces de realizar tareas complejas, tomar decisiones y ejecutar flujos de trabajo de principio a fin.",
    icon: "activity"
  },
  {
    title: "Análisis Predictivo",
    description: "Modelos que anticipan tendencias, comportamientos de clientes y optimizan la toma de decisiones basada en datos.",
    icon: "chart"
  },
  {
    title: "Automatización con RAG",
    description: "Retrieval-Augmented Generation para que la IA responda basándose únicamente en tu base de conocimiento corporativa.",
    icon: "shield"
  }
];
---

<Layout 
  title="Inteligencia Artificial Aplicada | Thinka"
  description="Integramos IA avanzada en tu negocio. Agentes autónomos, modelos LLM y automatización inteligente para optimizar procesos y reducir costos."
>
  <Navbar />
  
  <main class="bg-white dark:bg-gray-900">
    <!-- Hero AI -->
    <section class="relative py-24 lg:py-32 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-tr from-indigo-50 to-white dark:from-indigo-950/10 dark:to-gray-900 pointer-events-none"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div>
            <nav class="flex mb-8" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-2">
                <li><a href="/" class="text-sm text-gray-500 hover:text-indigo-600 transition-colors">Inicio</a></li>
                <li><Icon name="arrow-right" size={12} class="text-gray-400" /></li>
                <li><span class="text-sm font-bold text-indigo-600">Servicios</span></li>
              </ol>
            </nav>
            <h1 class="text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white leading-tight">
              Inteligencia <span class="text-indigo-600 italic">Artificial</span> Aplicada
            </h1>
            <p class="mt-8 text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
              No es solo IA, es inteligencia accionable. En Thinka transformamos el potencial de la Inteligencia Artificial en soluciones prácticas que ahorran miles de horas hombre y optimizan cada centavo de tu operación.
            </p>
            <div class="mt-12 flex flex-col sm:flex-row gap-4">
              <a href="/cotizar" class="inline-flex justify-center items-center px-8 py-4 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-all shadow-lg hover:shadow-indigo-500/25">
                Agenda Consultoría IA
              </a>
              <a href="#soluciones" class="inline-flex justify-center items-center px-8 py-4 border-2 border-gray-100 dark:border-gray-800 text-gray-600 dark:text-gray-300 font-bold rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
                Ver Soluciones
              </a>
            </div>
          </div>
          <div class="mt-16 lg:mt-0 relative">
             <div class="relative p-10 rounded-3xl overflow-hidden shadow-2xl border border-indigo-100 dark:border-indigo-900/40 bg-white/50 dark:bg-gray-800/50 backdrop-blur-xl">
               <div class="space-y-6">
                 <div class="h-4 bg-indigo-100 dark:bg-indigo-900/40 rounded-full w-3/4 animate-pulse"></div>
                 <div class="h-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-full w-full"></div>
                 <div class="h-4 bg-indigo-100 dark:bg-indigo-900/40 rounded-full w-1/2"></div>
                 <div class="grid grid-cols-3 gap-4 mt-8">
                   <div class="h-20 bg-indigo-200/20 rounded-2xl border border-indigo-100 dark:border-indigo-900/40 flex items-center justify-center">
                     <Icon name="cpu" size={32} class="text-indigo-600" />
                   </div>
                   <div class="h-20 bg-indigo-200/20 rounded-2xl border border-indigo-100 dark:border-indigo-900/40 flex items-center justify-center">
                     <Icon name="activity" size={32} class="text-indigo-600" />
                   </div>
                   <div class="h-20 bg-indigo-200/20 rounded-2xl border border-indigo-100 dark:border-indigo-900/40 flex items-center justify-center">
                     <Icon name="shield" size={32} class="text-indigo-600" />
                   </div>
                 </div>
               </div>
               <!-- Decorative AI pulse -->
               <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-indigo-500/20 rounded-full blur-[80px] animate-pulse"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solutions Grid -->
    <section id="soluciones" class="py-24 bg-gray-50 dark:bg-gray-800/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white">Nuestra Especialización</h2>
          <p class="mt-4 text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Tecnología de frontera adaptada a casos de uso empresariales reales.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {aiFeatures.map(f => (
            <div class="bg-white dark:bg-gray-900 p-8 rounded-3xl border border-gray-100 dark:border-gray-800 hover:shadow-xl transition-all duration-300 group">
              <div class="w-14 h-14 bg-indigo-50 dark:bg-indigo-900/30 rounded-2xl flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-6 group-hover:scale-110 transition-transform">
                <Icon name={f.icon as any} size={28} />
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">{f.title}</h3>
              <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Section -->
    <section class="py-24 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-indigo-600 rounded-[3rem] p-12 lg:p-20 relative overflow-hidden">
           <div class="relative z-10 lg:flex items-center justify-between">
             <div class="lg:max-w-xl">
               <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight">Expertos en Arquitecturas Token-Efficient</h2>
               <p class="mt-6 text-xl text-indigo-100 leading-relaxed">Optimizamos tus costos de API (OpenAI, Anthropic, Gemini) hasta en un 70% mediante técnicas avanzadas de prompt engineering y orquestación de modelos.</p>
             </div>
             <div class="mt-12 lg:mt-0 flex gap-6 flex-wrap lg:flex-nowrap">
               <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
                 <p class="text-3xl font-bold text-white">-70%</p>
                 <p class="text-indigo-100 text-sm mt-1">Costos de API</p>
               </div>
               <div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
                 <p class="text-3xl font-bold text-white">24/7</p>
                 <p class="text-indigo-100 text-sm mt-1">Disponibilidad</p>
               </div>
             </div>
           </div>
           <!-- Decorative background rings -->
           <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -mr-20 -mt-20 blur-3xl"></div>
           <div class="absolute bottom-0 left-0 w-64 h-64 bg-indigo-400/20 rounded-full -ml-20 -mb-20 blur-2xl"></div>
        </div>
      </div>
    </section>
  </main>

  <SimpleFooter />
</Layout>

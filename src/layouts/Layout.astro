---
import { SEO } from 'astro-seo';

interface Props {
	title: string;
	description?: string;
    image?: string;
    favicon?: string;
}

const { 
    title, 
    description = "Soluciones de Software, SaaS e Inteligencia Artificial. Consultoría tecnológica especializada en desarrollo a medida, automatización de procesos y transformación digital.",
    image = "/assets/images/og-image.jpg",
    favicon = "/favicon.svg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://thinka.cl/#organization",
      "name": "Thinka",
      "url": "https://thinka.cl",
      "logo": "https://thinka.cl/assets/images/logo-thinka.png",
      "sameAs": [
        "https://www.linkedin.com/company/thinka-cl",
        "https://www.facebook.com/people/Thinka-Desarrollo-de-Software-con-IA/61580902276921/",
        "https://www.instagram.com/thinka.cl/"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+56948894523",
        "contactType": "customer service",
        "areaServed": "Global",
        "availableLanguage": ["Spanish", "English"]
      },
      "description": description
    },
    {
      "@type": "WebSite",
      "@id": "https://thinka.cl/#website",
      "url": "https://thinka.cl",
      "name": "Thinka",
      "publisher": { "@id": "https://thinka.cl/#organization" }
    },
    {
      "@type": "Service",
      "serviceType": "Software Development",
      "provider": { "@id": "https://thinka.cl/#organization" },
      "areaServed": "Global",
      "description": "Desarrollo de Software a medida, plataformas SaaS e integración de Inteligencia Artificial."
    }
  ]
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={favicon} />
		<meta name="generator" content={Astro.generator} />
        
        <SEO
            title={title}
            description={description}
            canonical={canonicalURL.toString()}
            openGraph={{
                basic: {
                    title: title,
                    type: "website",
                    image: image,
                    url: canonicalURL.toString(),
                },
                optional: {
                    description: description,
                    locale: "es_ES",
                    siteName: "Thinka - Software, SaaS e IA",
                }
            }}
            twitter={{
                card: "summary_large_image",
                site: "@thinka_cl",
                creator: "@thinka_cl",
                title: title,
                description: description,
                image: image,
            }}
            extend={{
                meta: [
                    { name: "keywords", content: "Soluciones de Software, Desarrollo SaaS, Inteligencia Artificial, Automatización de procesos, Consultoría Tecnológica, Desarrollo Web, Software a Medida" },
                ],
            }}
        />

        <!-- JSON-LD -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

        <!-- Google Fonts Inter -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        <style is:global>
            /* Custom global styles if needed, mainly handled by Tailwind */
            body {
                font-family: 'Inter', sans-serif;
            }
        </style>
	</head>
	<body class="bg-white text-gray-900 antialiased dark:bg-gray-900 dark:text-gray-100">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-purple-600 text-white px-4 py-2 rounded-lg z-[60]">
			Saltar al contenido principal
		</a>
		<slot />

		<script is:inline>
			// Tracking placeholder
			function trackEvent(eventName, eventParams) {
				console.log(`[Tracking Event]: ${eventName}`, eventParams);
				if (typeof window.gtag === 'function') {
					window.gtag('event', eventName, eventParams);
				}
			}

			document.addEventListener('DOMContentLoaded', () => {
				const ctas = document.querySelectorAll('a[id], button[id]');
				ctas.forEach(cta => {
					cta.addEventListener('click', () => {
						trackEvent('click_cta', {
							cta_id: cta.id,
							cta_text: cta.innerText.trim(),
							page_path: window.location.pathname
						});
					});
				});
			});
		</script>
	</body>
</html>

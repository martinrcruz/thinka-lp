---
import { SEO } from 'astro-seo';

interface Props {
	title: string;
	description?: string;
    image?: string;
    favicon?: string;
}

const { 
    title, 
    description = "Automatización de procesos con IA. Consultoría tecnológica especializada en reducción de costos, desarrollo de software y transformación digital.",
    image = "/assets/images/og-image.jpg",
    favicon = "/favicon.svg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLD = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Thinka",
  "url": "https://thinka.cl",
  "logo": "https://thinka.cl/assets/logo/thinka-logo-cuadrado-fondo-uva.webp",
  "sameAs": [
    "https://www.linkedin.com/company/thinka-cl",
    "https://www.facebook.com/people/Thinka-Desarrollo-de-Software-con-IA/61580902276921/",
    "https://www.instagram.com/thinka.cl/"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+56948894523",
    "contactType": "customer service",
    "areaServed": "Global",
    "availableLanguage": ["Spanish", "English"]
  },
  "description": description
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={favicon} />
		<meta name="generator" content={Astro.generator} />
        
        <SEO
            title={title}
            description={description}
            canonical={canonicalURL.toString()}
            openGraph={{
                basic: {
                    title: title,
                    type: "website",
                    image: image,
                    url: canonicalURL.toString(),
                },
                optional: {
                    description: description,
                    locale: "es_ES",
                    siteName: "Thinka - Consultoría de IA",
                }
            }}
            twitter={{
                card: "summary_large_image",
                site: "@thinka_cl",
                creator: "@thinka_cl",
                title: title,
                description: description,
                image: image,
            }}
            extend={{
                meta: [
                    { name: "keywords", content: "Automatización de procesos con IA, Consultoría IA, Reducción de costos IA, Desarrollo de software con IA, Inteligencia Artificial, Optimización de modelos LLM" },
                ],
            }}
        />

        <!-- JSON-LD -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

        <!-- Google Fonts Inter -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        <style is:global>
            /* Custom global styles if needed, mainly handled by Tailwind */
            body {
                font-family: 'Inter', sans-serif;
            }
        </style>
	</head>
	<body class="bg-white text-gray-900 antialiased dark:bg-gray-900 dark:text-gray-100">
		<slot />
	</body>
</html>
